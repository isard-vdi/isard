{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Frontend Faro",
  "uid": "isardvdi-faro",
  "tags": ["isardvdi", "frontend", "faro"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "App",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({source=\"faro\"}, app)",
        "regex": "/^isardvdi-/",
        "multi": true,
        "includeAll": true
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({app=~\"$app\"}, app_environment)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "role",
        "label": "Role",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({app=~\"$app\"}, user_attr_role)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "app_version",
        "label": "App version",
        "type": "query",
        "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
        "query": "label_values({app=~\"$app\"}, app_version)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "client",
        "label": "API client",
        "type": "custom",
        "query": "api,apiv3,apiv4,auth,webapp",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "error_type",
        "label": "API error type",
        "type": "custom",
        "query": "http,network",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "status",
        "label": "API status",
        "type": "custom",
        "query": "400,401,403,404,408,409,422,429,500,502,503,504,0",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total errors",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "sum(count_over_time({app=~\"$app\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} | logfmt | kind=\"exception\" [$__range])) or vector(0)",
        "instant": true,
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Affected users",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "count(sum by (user_id) (count_over_time({app=~\"$app\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} | logfmt | kind=\"exception\" | user_id != \"\" [$__range]))) or vector(0)",
        "instant": true,
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sessions with errors",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "count(sum by (session_id) (count_over_time({app=~\"$app\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} | logfmt | kind=\"exception\" | session_id != \"\" [$__range]))) or vector(0)",
        "instant": true,
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total visits",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "sum(count_over_time({app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" ttfb=\" | logfmt | kind=\"measurement\" [$__range])) or vector(0)",
        "instant": true,
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short"
        }
      },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors over time (by type)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "sum by (type) (count_over_time({app=~\"$app\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} | logfmt | kind=\"exception\" [$__interval]))",
        "legendFormat": "{{type}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "fillOpacity": 60,
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": false,
            "showPoints": "auto"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "x": 0, "y": 5, "w": 16, "h": 8 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Visits over time",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "sum by (app) (count_over_time({app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" ttfb=\" | logfmt | kind=\"measurement\" [$__interval]))",
        "legendFormat": "{{app}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "spanNulls": true,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 8 }
    },

    {
      "id": 10,
      "type": "row",
      "title": "Web Vitals",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "TTFB",
      "description": "Time To First Byte — time from when the browser sends the request until it receives the first byte from the server. Measures network + server latency. Good: <600 ms.",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "avg(avg_over_time({app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" ttfb=\" | logfmt | kind=\"measurement\" | unwrap ttfb [$__range]))",
        "legendFormat": "TTFB",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 600 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "x": 0, "y": 14, "w": 6, "h": 4 }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "FCP",
      "description": "First Contentful Paint — time until the first visual element (text, image, SVG) appears on screen. Indicates when the user sees the page begin to load. Good: <1.8 s.",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "avg(avg_over_time({app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" fcp=\" | logfmt | kind=\"measurement\" | unwrap fcp [$__range]))",
        "legendFormat": "FCP",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1800 },
              { "color": "red", "value": 3000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "x": 6, "y": 14, "w": 6, "h": 4 }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "LCP",
      "description": "Largest Contentful Paint — time until the largest viewport element (usually the main image or heading) appears. Indicates when the page is visually usable. Good: <2.5 s.",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "avg(avg_over_time({app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" lcp=\" | logfmt | kind=\"measurement\" | unwrap lcp [$__range]))",
        "legendFormat": "LCP",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 2500 },
              { "color": "red", "value": 4000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "x": 12, "y": 14, "w": 6, "h": 4 }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "CLS",
      "description": "Cumulative Layout Shift — dimensionless measure of unexpected layout shifts during page load (weighted sum of changes). Good: <0.1.",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "avg(avg_over_time({app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" cls=\" | logfmt | kind=\"measurement\" | unwrap cls [$__range]))",
        "legendFormat": "CLS",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.1 },
              { "color": "red", "value": 0.3 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "x": 18, "y": 14, "w": 6, "h": 4 }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Web Vitals trends (p75)",
      "description": "p75 of TTFB, FCP and LCP from the Faro web-vitals events.",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "quantile_over_time(0.75, {app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" ttfb=\" | logfmt | kind=\"measurement\" | unwrap ttfb [5m]) by (app)",
          "legendFormat": "TTFB",
          "refId": "A"
        },
        {
          "expr": "quantile_over_time(0.75, {app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" fcp=\" | logfmt | kind=\"measurement\" | unwrap fcp [5m]) by (app)",
          "legendFormat": "FCP",
          "refId": "B"
        },
        {
          "expr": "quantile_over_time(0.75, {app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" lcp=\" | logfmt | kind=\"measurement\" | unwrap lcp [5m]) by (app)",
          "legendFormat": "LCP",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 0,
            "spanNulls": true,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "gridPos": { "x": 0, "y": 18, "w": 16, "h": 8 }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "CLS (p75)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "quantile_over_time(0.75, {app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} |= \" cls=\" | logfmt | kind=\"measurement\" | unwrap cls [5m]) by (app)",
        "legendFormat": "CLS",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 0,
            "spanNulls": true,
            "showPoints": "auto",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 8 }
    },

    {
      "id": 60,
      "type": "row",
      "title": "Page performance",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 62,
      "type": "stat",
      "title": "Page load (p75)",
      "description": "Total page load time = domComplete - fetchStart. End-to-end time from request start to fully rendered DOM.",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "avg(quantile_over_time(0.75, {app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} | logfmt | event_name=\"faro.performance.navigation\" | event_data_pageLoadTime != \"unknown\" | unwrap event_data_pageLoadTime [$__range]))",
        "legendFormat": "p75",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 3000 },
              { "color": "red", "value": 6000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "x": 0, "y": 27, "w": 8, "h": 4 }
    },
    {
      "id": 63,
      "type": "stat",
      "title": "DOM processing (p75)",
      "description": "Time the browser spent parsing and executing scripts to make the DOM interactive (domComplete - domInteractive).",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "avg(quantile_over_time(0.75, {app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} | logfmt | event_name=\"faro.performance.navigation\" | event_data_domProcessingTime != \"unknown\" | unwrap event_data_domProcessingTime [$__range]))",
        "legendFormat": "p75",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1000 },
              { "color": "red", "value": 3000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "x": 8, "y": 27, "w": 8, "h": 4 }
    },
    {
      "id": 64,
      "type": "stat",
      "title": "onLoad handler (p75)",
      "description": "Duration of the window 'load' event handler (loadEventEnd - loadEventStart). High values point to expensive load-time JS.",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{
        "expr": "avg(quantile_over_time(0.75, {app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} | logfmt | event_name=\"faro.performance.navigation\" | event_data_onLoadTime != \"unknown\" | unwrap event_data_onLoadTime [$__range]))",
        "legendFormat": "p75",
        "refId": "A"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "x": 16, "y": 27, "w": 8, "h": 4 }
    },
    {
      "id": 65,
      "type": "timeseries",
      "title": "Page load breakdown (p75)",
      "description": "Per-phase breakdown of navigation timing at p75. Stacked bars show where time is spent.",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "expr": "avg(quantile_over_time(0.75, {app=~\"$app\", source=\"faro\", app_environment=~\"$environment\", user_attr_role=~\"$role\", app_version=~\"$app_version\"} | logfmt | event_name=\"faro.performance.navigation\" | event_data_ttfb != \"unknown\" | unwrap event_data_ttfb [5m]))",
          "legendFormat": "TTFB",
          "refId": "A"
