def _find_templates_without_dependents(raw_storages):
    """Find ready templates that no other desktop or template depends on.

    A template without dependents is one where no other storage (template
    or desktop) references it as parent, or all children have status=deleted.
    These are informational — not auto-deleted, but reported for admin review.

    Returns list of dicts sorted by size descending.
    """
    # Build parent -> active children map
    children_of = {}
    for s in raw_storages:
        pid = s.get("parent")
        if pid and s["status"] != "deleted":
            children_of.setdefault(pid, []).append(s["id"])

    # Count all children (including deleted) for context
    all_children_of = {}
    for s in raw_storages:
        pid = s.get("parent")
        if pid:
            all_children_of.setdefault(pid, []).append(s["id"])

    result = []
    for s in raw_storages:
        if s["status"] != "ready":
            continue
        if "/templates" not in s.get("directory_path", ""):
            continue

        active_kids = children_of.get(s["id"], [])
        if active_kids:
            continue  # has active dependents

        all_kids = all_children_of.get(s["id"], [])
        path = s["path"]
        try:
            size = Path(path).stat().st_size
        except OSError:
            size = 0

        result.append(
            {
                "id": s["id"],
                "path": path,
                "size": size,
                "domains": s.get("domains", 0),
                "user_id": s.get("user_id", "?"),
                "deleted_children": len(all_kids),
            }
        )

    result.sort(key=lambda x: x["size"], reverse=True)
    return result


def _classify_media_files(media_files, medias):
    """Classify on-disk .iso/.fd files against the API's media table.

    Match in three steps: UUID stem (canonical identifier for API-downloaded
    files), inode equality with the DB-recorded path (handles bind mounts and
    hard links — e.g. /isard/media bind-mounted from a storage_pool), then
    literal path equality. The inode step covers human-named manual uploads
    whose DB path differs from the discovered path due to a bind mount.

    Returns dict with four lists of paths:
        registered:        on disk + API match (UUID, inode, or literal path)
                           with status="Downloaded". Healthy, do not delete.
        unverified:        on disk, UUID is in API but not Downloaded yet
                           is referenced by VM domains. Defensive — review.
        orphan:            on disk, no API match, no domain reference.
                           Safe to delete after manual review.
        db_not_in_system:  API has status="Downloaded" but no on-disk file
                           matches by path, UUID, or inode. Operator review.

    Status semantics: only status="Downloaded" is "should exist on disk"
    (see api/src/api/libv2/api_media.py:91-105).
    """
    media_by_path = {m["path_downloaded"]: m for m in medias}
    media_by_id = {m["id"]: m for m in medias}

    # Inode index of every Downloaded media's recorded path that exists on
    # disk — bind-mount-safe lookup for files we discover at a different path.
    inode_to_media = {}
    for m in medias:
        if m.get("status") != "Downloaded":
            continue
        try:
            st = os.stat(m["path_downloaded"])
        except OSError:
            continue
        inode_to_media[(st.st_dev, st.st_ino)] = m

    registered = []
    unverified = []
    orphan = []
    matched_inodes = set()

    for f in media_files:
        f_str = str(f)
        stem = Path(f_str).stem

        match_id = media_by_id.get(stem)
        if match_id and match_id.get("status") == "Downloaded":
            registered.append(f_str)
            continue

        match_path = media_by_path.get(f_str)
        if match_path and match_path.get("status") == "Downloaded":
            registered.append(f_str)
            continue

        try:
            st = os.stat(f_str)
            key = (st.st_dev, st.st_ino)
        except OSError:
            key = None
        if key is not None and key in inode_to_media:
            registered.append(f_str)
            matched_inodes.add(key)
            continue

        if match_id and match_id.get("domains", 0) > 0:
            unverified.append(f_str)
            continue

        orphan.append(f_str)

    on_disk_paths = {str(f) for f in media_files}
    on_disk_uuids = {Path(f).stem for f in media_files}
    db_not_in_system = []
    for m in medias:
        if m.get("status") != "Downloaded":
            continue
        path = m["path_downloaded"]
        if path in on_disk_paths:
            continue
        if m["id"] in on_disk_uuids:
            continue
        try:
            st = os.stat(path)
            if (st.st_dev, st.st_ino) in matched_inodes:
                continue
        except OSError:
            pass
        db_not_in_system.append(path)

    return {
        "registered": registered,
        "unverified": unverified,
        "orphan": orphan,
        "db_not_in_system": db_not_in_system,
    }


def _classify_non_qcow2_files(non_qcow_files, qcow_deps, db_storage_lookup=None):
    """Classify non-qcow2 files into dead artifacts vs unknown.

    Dead artifacts: any non-.qcow2 file in storage directories that is not
    used as a backing file by any qcow2 on disk. This includes renamed
    qcow2 copies (.sin_bc, .copia, .bkp, .sha256, .ram, etc.) and any
    other non-qcow2 files that ended up in storage dirs.

    Files in any /media/ path are excluded (ISOs/FDs, including under storage_pools).

    Special case: a `*.sparsify-backup` file is the recovery copy of its
    sibling `*.qcow2`; the whole point of keeping it is to be able to
    restore the canonical file if it ever turned out broken. We therefore
    only mark such a backup as "dead" when ALL of:
      - the canonical .qcow2 exists on disk
      - qemu-img check on the canonical reports no errors
      - the canonical's UUID is in the API storage table with status=ready
        (or no API lookup was passed in, in which case we skip this check)
    Otherwise we keep the backup as "unknown" so it survives any cleanup.

    Returns (dead_artifacts, unknown_files)
    """
    reverse_map = qcow_deps.get("reverse_map", {})
    dead = []
    unknown = []

    for f in non_qcow_files:
        f_str = str(f)
        if "/media/" in f_str:
            unknown.append(f_str)
            continue
        # Check if any qcow2 references this file as backing
        if f_str in reverse_map:
            unknown.append(f_str)
            continue
        # Sparsify backups: keep unless the canonical qcow2 is provably
        # healthy. Without this guard, a corrupt canonical would be
        # treated as an orphan and its only-good copy moved to to_delete.
        if f_str.endswith(".qcow2.sparsify-backup"):
            canonical = f_str[: -len(".sparsify-backup")]
            if not Path(canonical).is_file():
                unknown.append(f_str)
                continue
            if not qemu_img_check(canonical):
                unknown.append(f_str)
                continue
            if db_storage_lookup is not None:
                info = db_storage_lookup.get(canonical)
                if not info or info.get("status") != "ready":
                    unknown.append(f_str)
                    continue
            dead.append(f_str)
            continue
        dead.append(f_str)

    return dead, unknown


def _find_duplicate_uploads(qcow_storages, db_storage_lookup):
    """Find qcow2 files that are duplicates of DB-tracked files at a different path.

    A file is a duplicate if:
    - Its UUID matches a DB storage ID
    - The DB-referenced path is different from this file's path
    - The file at the DB-referenced path EXISTS on disk (the DB copy is the real one)
    - This file is not the DB-referenced path itself

    Returns list of duplicate file paths (safe to remove).
    """
    # Build ID -> DB path lookup
    id_to_db_path = {}
    for path, info in db_storage_lookup.items():
        id_to_db_path[info["id"]] = path

    duplicates = []
    for f in qcow_storages:
        f_str = str(f)
        uid = Path(f_str).stem
        db_path = id_to_db_path.get(uid)
        if not db_path:
            continue  # not in DB
        if db_path == f_str:
            continue  # this IS the DB copy
        # DB has a different path for this UUID — check if the DB copy exists
        if Path(db_path).exists():
            duplicates.append(f_str)

    return duplicates


def _analyze_chain_health(qcow_deps, raw_storages, depth_threshold=3):
    """Analyze backing chain depth and structure.

    Returns dict with:
        files: list of per-file info (id, path, depth, children_count, etc.)
        roots: list of root info dicts (id, path, descendants, max_depth)
        deep: files with depth > depth_threshold
        single_dependent: intermediate templates with exactly 1 child
                          (flattening candidates)
        max_depth: deepest chain found
        avg_depth: average depth across all files
    """
    dep_map = qcow_deps.get("dependency_map", {})
    rev_map = qcow_deps.get("reverse_map", {})

    # Build storage info lookup by path
    storage_by_path = {}
    for s in raw_storages:
        storage_by_path[s["path"]] = s

    # Compute depth for every file (cached)
    depth_cache = {}

    def _depth(f):
        if f in depth_cache:
            return depth_cache[f]
        parent = dep_map.get(f)
        if not parent:
            depth_cache[f] = 0
            return 0
        d = 1 + _depth(parent)
        depth_cache[f] = d
        return d

    for f in dep_map:
        _depth(f)

    # Count all descendants for each file
    def _all_descendants(f):
        result = set()
        stack = list(rev_map.get(f, []))
        while stack:
            c = stack.pop()
            if c not in result:
                result.add(c)
                stack.extend(rev_map.get(c, []))
        return result

    # Build per-file info
    files = []
    for f, parent in dep_map.items():
        children = rev_map.get(f, [])
        db = storage_by_path.get(f, {})
        files.append(
            {
                "path": f,
                "id": Path(f).stem,
                "depth": depth_cache.get(f, 0),
                "is_root": parent is None,
                "is_leaf": len(children) == 0,
                "children_count": len(children),
                "status": db.get("status", "?"),
                "domains": db.get("domains", 0),
                "user_id": db.get("user_id", "?"),
                "is_template": "/templates" in f,
            }
        )

    # Roots with their subtree info
    roots = []
    for fi in files:
        if fi["is_root"]:
            desc = _all_descendants(fi["path"])
            max_d = max((depth_cache.get(d, 0) for d in desc), default=0)
            roots.append(
                {
                    "id": fi["id"],
                    "path": fi["path"],
                    "descendants": len(desc),
                    "max_depth": max_d,
                }
            )
    roots.sort(key=lambda x: x["max_depth"], reverse=True)

    # Deep chains
    deep = [fi for fi in files if fi["depth"] > depth_threshold]
    deep.sort(key=lambda x: x["depth"], reverse=True)

    # Single-dependent intermediates (flattening candidates)
    # Must have: exactly 1 child, has a parent (not root), is a template
    single_dependent = []
    for fi in files:
        if fi["is_root"] or fi["is_leaf"]:
            continue
        if fi["children_count"] != 1:
            continue
        if not fi["is_template"]:
            continue
        child_path = rev_map[fi["path"]][0]
        child_depth = depth_cache.get(child_path, 0)
        single_dependent.append(
            {
                **fi,
                "child_path": child_path,
                "child_id": Path(child_path).stem,
                "child_depth": child_depth,
            }
        )
    single_dependent.sort(key=lambda x: x["depth"], reverse=True)

    # Stats
    depths = [fi["depth"] for fi in files]
    max_d = max(depths) if depths else 0
    avg_d = sum(depths) / len(depths) if depths else 0

    return {
        "files": files,
        "roots": roots,
        "deep": deep,
        "single_dependent": single_dependent,
        "max_depth": max_d,
        "avg_depth": avg_d,
        "depth_threshold": depth_threshold,
    }


def _print_chain_tree(root_path, rev_map, depth_cache, storage_by_path, indent=0):
    """Print a tree view of a chain starting from root."""
    rid = Path(root_path).stem
    db = storage_by_path.get(root_path, {})
    depth = depth_cache.get(root_path, 0)
    children = rev_map.get(root_path, [])
    domains = db.get("domains", 0)
    is_tmpl = "/templates" in root_path

    prefix = "  " * indent
    kind = "T" if is_tmpl else "D"
    dom_str = f" dom={domains}" if domains else ""
    child_str = f" [{len(children)} children]" if children else " [leaf]"
    print(f"{prefix}{kind} {rid} (depth={depth}{dom_str}{child_str})")

    for child in sorted(children):
        _print_chain_tree(child, rev_map, depth_cache, storage_by_path, indent + 1)


# ─── move helpers ─────────────────────────────────────────────────────────────

TO_DELETE_DIR = "/isard/volatile/to_delete"


def _collect_movable_files(
    deletable_orphans,
    volatile,
    db_storage_lookup,
    qcow_deps,
    dead_artifacts=None,
    duplicate_uploads=None,
    orphan_medias=None,
    include_templates=False,
):
    """Collect files that are SAFE to move, grouped by category.

    Safety rules:
    - Moves deletable_orphans (not in DB + no derivatives), dead broken chains,
      dead artifacts (non-qcow2 not in any chain), duplicate uploads, orphan
      medias (ISO/FD with no API match), and volatile.
    - The /media/ path rejection only applies to qcow2 orphan verification.
      Orphan medias are pre-verified by _classify_media_files against the
      API media table, so they bypass that filter (passed as their own
      category, not via deletable_orphans).
    - Performs extra verification on orphans: double-checks against DB.
      Files found in DB are rejected UNLESS DB status is "deleted".
    - Dead artifacts, duplicate uploads, and orphan medias are pre-verified
      by their respective classification functions — they just get the
      template filter applied.
    - Templates are excluded unless include_templates is True.

    Returns dict: {category_label: [file_paths]}
    """
    # Extra safety: verify each orphan is truly safe to move
    verified_orphans = []
    rejected = 0
    for f in deletable_orphans:
        f_str = str(f)
        if "/media/" in f_str:
            rejected += 1
            continue
        db_info = db_storage_lookup.get(f_str)
        if db_info is not None and db_info["status"] != "deleted":
            rejected += 1
            continue
        storage_id = Path(f_str).stem
        found_active_in_db = False
        for path, info in db_storage_lookup.items():
            if info["id"] == storage_id and info["status"] != "deleted":
                found_active_in_db = True
                break
        if found_active_in_db:
            rejected += 1
            continue
        if f_str in qcow_deps.get("reverse_map", {}):
            rejected += 1
            continue
        verified_orphans.append(f_str)

    if rejected:
        log(
            f"Safety check: rejected {rejected} files that appeared orphaned"
            " but were found in DB or have derivatives."
        )

    categories = {
        "deletable_orphans": verified_orphans,
        "dead_artifacts": list(dead_artifacts or []),
        "duplicate_uploads": list(duplicate_uploads or []),
        "orphan_medias": [str(f) for f in (orphan_medias or [])],
        "volatile": [str(f) for f in volatile],
    }

    if not include_templates:
        skipped = 0
        for cat, files in categories.items():
            before = len(files)
            categories[cat] = [f for f in files if "/isard/templates" not in str(f)]
            skipped += before - len(categories[cat])
        if skipped:
            log(
                f"WARNING: Skipped {skipped} template files."
                " Use --include-templates to include them."
            )

    return categories


def _verify_orphans(deletable_orphans, db_storage_lookup, qcow_deps):
    """Re-check orphan candidates against the live DB before moving.

    Same safety logic as _collect_movable_files, factored out so the
    interactive flow can reuse it without redoing every other category.
    Returns (verified_orphans, rejected_count).
    """
    verified = []
    rejected = 0
    for f in deletable_orphans:
        f_str = str(f)
        if "/media/" in f_str:
            rejected += 1
            continue
        db_info = db_storage_lookup.get(f_str)
        if db_info is not None and db_info["status"] != "deleted":
            rejected += 1
            continue
        storage_id = Path(f_str).stem
        found_active = False
        for path, info in db_storage_lookup.items():
            if info["id"] == storage_id and info["status"] != "deleted":
                found_active = True
                break
        if found_active:
            rejected += 1
            continue
        if f_str in qcow_deps.get("reverse_map", {}):
            rejected += 1
            continue
        verified.append(f_str)
    return verified, rejected


def _prompt_yn(message, default="n"):
    """Prompt for y/n/q. Returns 'y', 'n', or 'q'.

    Empty input returns the default. EOF or Ctrl-C returns 'q'.
    """
    while True:
        try:
            answer = input(message).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return "q"
        if not answer:
            return default
        if answer in ("y", "yes"):
            return "y"
        if answer in ("n", "no"):
            return "n"
        if answer in ("q", "quit", "abort"):
            return "q"
        print("  Please answer y, n, or q.")


def _bucket_mount(path):
    """Return a coarse mount label for a path — used for the by-mount summary."""
    if path.startswith("/isard/storage_pools/vdo3/"):
        return "vdo3"
    return "fast"


def _print_bucket_summary(non_templates, templates):
    """Counts, sizes, mount split, and a top-by-size sample for one bucket."""
    from collections import Counter

    def _stat_size(p):
        try:
            return Path(p).stat().st_size
        except OSError:
            return 0

    nt_sized = sorted(((_stat_size(f), str(f)) for f in non_templates), reverse=True)
    t_sized = sorted(((_stat_size(f), str(f)) for f in templates), reverse=True)
    nt_total = sum(s for s, _ in nt_sized)
    t_total = sum(s for s, _ in t_sized)
    mounts = Counter(_bucket_mount(p) for _, p in nt_sized + t_sized)

    print(
        f"  Non-templates: {len(non_templates):>6} files  {format_size(nt_total):>10}"
    )
    if templates:
        print(f"  Templates:     {len(templates):>6} files  {format_size(t_total):>10}")
    if mounts:
        mount_str = ", ".join(f"{k}={v}" for k, v in mounts.most_common())
        print(f"  By mount:      {mount_str}")

    sample = nt_sized[:5] if nt_sized else t_sized[:5]
    if sample:
        print("  Sample (largest):")
        for size, path in sample:
            print(f"    {format_size(size):>10}  {path}")
        more = len(non_templates) + len(templates) - len(sample)
        if more > 0:
            print(f"    ... and {more} more")


def _interactive_cleanup(
    output_dir,
    deletable,
    volatile,
    dead_non_qcow,
    orphan_medias,
    broken_chain,
    qcow_deps,
    db_storage_lookup,
    storages_in_system_not_in_db,
):
    """Walk through deletable buckets in safety order, prompting per step.

    Calls _move_deletable_files(append=True) once per accepted sub-step so
    the manifest at output_dir/moved_files.txt records every accepted move.
    """
    verified_orphans, rejected = _verify_orphans(
        deletable, db_storage_lookup, qcow_deps
    )
    if rejected:
        log(
            f"Safety check: rejected {rejected} orphan candidates that"
            " appeared in DB or are still referenced. They will not be offered."
        )

    # Broken-chain subset that's unambiguously safe: no DB record AND no
    # children. Any other broken-chain entry is too risky for this flow.
    broken_safe = (
        set(broken_chain)
        & storages_in_system_not_in_db
        & set(qcow_deps.get("wo_derivatives", []))
    )
    broken_safe -= set(verified_orphans)  # don't list a file twice

    steps = [
        (
            "volatile",
            "Volatile storage",
            "Ephemeral files in /isard/volatile/. Always safe to remove.",
            list(volatile),
        ),
        (
            "dead_artifacts",
            "Dead non-qcow2 artifacts",
            "Non-qcow2 files (.json, .backup, .copia, .sha256, …) verified not"
            " to be used as backing for any chain.",
            list(dead_non_qcow),
        ),
        (
            "deletable_orphans",
            "Orphan qcow2 (not in DB, no derivatives)",
            "qcow2 files with no API record and no children. Re-verified"
            " against the live DB.",
            verified_orphans,
        ),
        (
            "orphan_medias",
            "Orphan ISO/FD media",
            "ISO/FD media files with no Downloaded API record and not"
            " referenced by any VM domain. Bind-mount-safe match.",
            list(orphan_medias),
        ),
        (
            "broken_chain_dead",
            "Broken chains (unrecoverable, not in DB, no derivatives)",
            "qcow2 files whose backing parent is missing AND that have no DB"
            " record AND no children. The chain is unrecoverable either way.",
            sorted(broken_safe),
        ),
    ]

    print()
    print("=" * 70)
    print("INTERACTIVE CLEANUP — review each bucket and confirm")
    print(f"Files will be moved to: {TO_DELETE_DIR}")
    print(f"Manifest:               {output_dir / 'moved_files.txt'}")
    print("Order: safest → least safe.  [y]es / [N]o / [q]uit")
    print("=" * 70)

    quit_now = False
    total_moved = 0
    total_failed = 0

    for i, (cat, label, description, files) in enumerate(steps, 1):
        print()
        print("-" * 70)
        print(f"[{i}/{len(steps)}] {label}")
        for line in description.split("\n"):
            print(f"  {line}")

        if quit_now:
            print("  (skipped — quit requested)")
            continue

        if not files:
            print("  (nothing to move — skipping)")
            continue

        templates = [f for f in files if "/isard/templates" in str(f)]
        non_templates = [f for f in files if "/isard/templates" not in str(f)]

        _print_bucket_summary(non_templates, templates)

        if non_templates:
            choice = _prompt_yn(
                f"\n  Move {len(non_templates)} non-template files? [y/N/q]: ",
            )
            if choice == "q":
                quit_now = True
                continue
            if choice == "y":
                pre_failed = (output_dir / "move_failures.txt").exists()
                _move_deletable_files({cat: non_templates}, output_dir, append=True)
                total_moved += len(non_templates)
                if pre_failed != (output_dir / "move_failures.txt").exists():
                    total_failed += 1  # rough — manifest is the source of truth
        else:
            print("  (only templates in this bucket)")

        if templates and not quit_now:
            print()
            print(
                f"  WARNING: {len(templates)} template files in this bucket."
                " Templates may be referenced by users outside the API."
            )
            choice_t = _prompt_yn(
                f"  Also move {len(templates)} template files? [y/N/q]: ",
            )
            if choice_t == "q":
                quit_now = True
                continue
            if choice_t == "y":
                _move_deletable_files(
                    {cat + "_templates": templates},
                    output_dir,
                    append=True,
                )
                total_moved += len(templates)

    print()
    print("=" * 70)
    print("Interactive cleanup finished.")
    if total_moved:
        print(f"Files queued/moved this session: {total_moved}")
        print(f"Manifest: {output_dir / 'moved_files.txt'}")
        print()
        print("To permanently delete all moved files:")
        print(f"  rm -rf {TO_DELETE_DIR}")
        print()
        print("To restore everything:")
        print(
            f"  cd {TO_DELETE_DIR} && find . -type f -exec sh -c"
            f' \'mv "$1" "/$(dirname "$1")"\' _ {{}} \\;'
        )
    else:
        print("No files were moved.")
    print("=" * 70)


def _move_deletable_files(categories, output_dir, append=False, dry_run=False):
    """Move all deletable files to /isard/volatile/to_delete/, preserving path structure.

    Files are moved as: /isard/groups/abc.qcow2 -> /isard/volatile/to_delete/isard/groups/abc.qcow2

    A manifest of moved files is saved to output_dir/moved_files.txt. With
    append=True the manifest and failures files are opened in append mode so
    multiple invocations (e.g. interactive cleanup steps) accumulate into a
    single record.

    With dry_run=True the function only prints the summary table and writes
    a `would_move.txt` manifest in `output_dir`; no files are moved.
    """
    # Deduplicate across categories
    seen = set()
    all_files = []
    for cat, files in categories.items():
        for f in files:
            f_str = str(f)
            if f_str not in seen:
                seen.add(f_str)
                all_files.append((cat, f_str))

    if not all_files:
        log("No files to move.")
        return

    # Print summary before moving
    print()
    print("=" * 70)
    print("FILES TO MOVE TO", TO_DELETE_DIR)
    print("=" * 70)

    cat_summary = {}
    total_size = 0
    for cat, f in all_files:
        if cat not in cat_summary:
            cat_summary[cat] = {"count": 0, "size": 0}
        cat_summary[cat]["count"] += 1
        try:
            cat_summary[cat]["size"] += Path(f).stat().st_size
            total_size += Path(f).stat().st_size
        except OSError:
            pass

    labels = {
        "deletable_orphans": "Deletable orphans (not in DB, no derivatives)",
        "dead_artifacts": "Dead artifacts (non-qcow2, not in any chain)",
        "duplicate_uploads": "Duplicate uploads (DB copy exists)",
        "volatile": "Volatile storage",
    }
    for cat in ["deletable_orphans", "dead_artifacts", "duplicate_uploads", "volatile"]:
        if cat in cat_summary:
            s = cat_summary[cat]
            print(
                f"  {labels.get(cat, cat):<50}"
                f" {s['count']:>6} files  {format_size(s['size']):>10}"
            )
    print(f"  {'TOTAL':<50} {len(all_files):>6} files  {format_size(total_size):>10}")
    print("=" * 70)
    print()

    if dry_run:
        manifest_path = output_dir / "would_move.txt"
        with open(manifest_path, "w") as mf:
            for cat, f in all_files:
                mf.write(f"{cat}\t{f}\n")
        log(f"DRY RUN: {len(all_files)} files would be moved (see {manifest_path})")
        return

    # Perform moves — manifest is written incrementally so it's always
    # consistent with what was actually moved, even if interrupted.
    manifest_path = output_dir / "moved_files.txt"
    failed_path = output_dir / "move_failures.txt"
    moved_count = 0
    failed_count = 0

    total_files = len(all_files)
    moved_bytes = 0
    start_time = time()
    last_log = start_time

    open_mode = "a" if append else "w"
    with open(manifest_path, open_mode) as mf, open(failed_path, open_mode) as ff:
        for idx, (cat, f) in enumerate(all_files, 1):
            src = Path(f)
            if not src.exists():
                ff.write(f"{f}\tnot found\n")
                failed_count += 1
                continue

            try:
                file_size = src.stat().st_size
            except OSError:
                file_size = 0

            # Preserve full path under to_delete:
            #   /isard/groups/x.qcow2 -> to_delete/isard/groups/x.qcow2
            rel_path = str(src).lstrip("/")
            dest = Path(TO_DELETE_DIR) / rel_path

            try:
                dest.parent.mkdir(parents=True, exist_ok=True)
                shutil.move(str(src), str(dest))
                mf.write(f"{cat}\t{f}\t{dest}\n")
                mf.flush()
                moved_count += 1
                moved_bytes += file_size
            except OSError as e:
                log(f"  FAIL: {f} -> {e}")
                ff.write(f"{f}\t{e}\n")
                ff.flush()
                failed_count += 1

            # Progress every 10s or every 20 files
            now = time()
            if now - last_log >= 10 or idx % 20 == 0 or idx == total_files:
                elapsed = now - start_time
                pct = idx / total_files * 100
                rate = idx / elapsed if elapsed > 0 else 0
                eta = (total_files - idx) / rate if rate > 0 else 0
                log(
                    f"  Moving: {idx}/{total_files} ({pct:.0f}%)"
                    f" | {format_size(moved_bytes)} moved"
                    f" | ETA {format_time_remaining(eta)}"
                )
                last_log = now

    log(f"Moved {moved_count} files to {TO_DELETE_DIR}")
    if failed_count:
        log(f"Failed to move {failed_count} files (see {failed_path})")

    # Clean up empty failures file (only safe in non-append mode — in append
    # mode a previous step may have written failures we shouldn't drop).
    if failed_count == 0 and not append:
        failed_path.unlink(missing_ok=True)

    print()
    print(f"Moved:  {moved_count} files")
    print(f"Failed: {failed_count} files")
    print(f"Destination: {TO_DELETE_DIR}")
    print(f"Manifest: {manifest_path}")
    print()
    print("To permanently delete all moved files:")
    print(f"  rm -rf {TO_DELETE_DIR}")
    print()
    print("To restore a specific file (path tree is preserved):")
    print(f"  # e.g. /isard/groups/abc.qcow2 was moved to")
    print(f"  #      {TO_DELETE_DIR}/isard/groups/abc.qcow2")
    print(f"  mv {TO_DELETE_DIR}/isard/groups/abc.qcow2 /isard/groups/abc.qcow2")
    print()
    print("To restore everything:")
    print(
        f'  cd {TO_DELETE_DIR} && find . -type f -exec sh -c \'mv "$1" "/$(dirname "$1")"\' _ {{}} \\;'
    )


