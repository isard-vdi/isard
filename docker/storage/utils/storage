def cmd_chains(args):
    """Analyze and optionally flatten backing chain depth."""
    t = time()
    log("Starting chain analysis...")

    raw_storages = fetch_storages()
    if raw_storages is None:
        log("ERROR: API call failed.")
        sys.exit(1)

    sys_storages = scan_isard_dirs()
    qcow_storages = [s for s in sys_storages if s.endswith(".qcow2")]

    log("Analyzing dependencies...")
    qcow_deps = analyze_dependencies(qcow_storages)

    threshold = args.max_depth
    health = _analyze_chain_health(qcow_deps, raw_storages, depth_threshold=threshold)

    # Build lookups for tree printing
    storage_by_path = {s["path"]: s for s in raw_storages}
    dep_map = qcow_deps.get("dependency_map", {})
    rev_map = qcow_deps.get("reverse_map", {})
    depth_cache = {}
    for fi in health["files"]:
        depth_cache[fi["path"]] = fi["depth"]

    # Report
    print()
    print("=" * 70)
    print("CHAIN DEPTH ANALYSIS")
    print("=" * 70)
    print(f"  Total files:    {len(health['files'])}")
    print(f"  Root templates: {len(health['roots'])}")
    print(f"  Max depth:      {health['max_depth']}")
    print(f"  Average depth:  {health['avg_depth']:.1f}")
    print(f"  Threshold:      {threshold}")
    print("=" * 70)

    # Deep chains
    if health["deep"]:
        print(f"\nDeep chains (depth > {threshold}): {len(health['deep'])}")
        for fi in health["deep"]:
            kind = "template" if fi["is_template"] else "desktop"
            dom_str = f"  domains={fi['domains']}" if fi["domains"] else ""
            print(f"  depth={fi['depth']}  {kind}  {fi['id']}{dom_str}")
    else:
        print(f"\nNo chains deeper than {threshold}.")

    # Single-dependent intermediates
    if health["single_dependent"]:
        print(
            f"\nFlattening candidates (single-dependent intermediates):"
            f" {len(health['single_dependent'])}"
        )
        for sd in health["single_dependent"]:
            print(f"  {sd['id']} (depth={sd['depth']}, 1 child)")
            print(
                f"    child: {sd['child_id']} (depth={sd['child_depth']})"
                f" -> disconnect would reduce to depth 0"
            )
    else:
        print("\nNo single-dependent intermediates found.")

    # Chain trees (top 10 by max depth, or all if --verbose)
    print(f"\nChain trees (sorted by max depth):")
    show_roots = health["roots"]
    if not args.verbose and len(show_roots) > 10:
        show_roots = show_roots[:10]
        print(f"  (showing top 10 of {len(health['roots'])}, use --verbose for all)")

    for root in show_roots:
        print(
            f"\n  Root: {root['id']}"
            f" ({root['descendants']} descendants, max depth {root['max_depth']})"
        )
        _print_chain_tree(
            root["path"], rev_map, depth_cache, storage_by_path, indent=2
        )

    print()
    print("=" * 70)

    # Flatten mode
    to_flatten = []

    if args.flatten_singles and health["single_dependent"]:
        for sd in health["single_dependent"]:
            to_flatten.append({
                "id": sd["child_id"],
                "path": sd["child_path"],
                "reason": f"single-dependent parent {sd['id']}",
                "depth": sd["child_depth"],
            })

    if args.flatten_deep and health["deep"]:
        seen = {f["id"] for f in to_flatten}
        for fi in health["deep"]:
            if fi["is_leaf"] and fi["id"] not in seen:
                to_flatten.append({
                    "id": fi["id"],
                    "path": fi["path"],
                    "reason": f"depth {fi['depth']} > {args.flatten_deep}",
                    "depth": fi["depth"],
                })

    if not to_flatten:
        if args.flatten_singles or args.flatten_deep:
            log("No files to flatten.")
        log(f"Total execution time: {time()-t:.2f} seconds")
        return

    # Filter templates
    if not args.include_templates:
        before = len(to_flatten)
        to_flatten = [f for f in to_flatten if "/isard/templates" not in f["path"]]
        skipped = before - len(to_flatten)
        if skipped:
            log(
                f"Skipping {skipped} template files."
                " Use --include-templates to include them."
            )

    if not to_flatten:
        log("No files to flatten after filtering.")
        log(f"Total execution time: {time()-t:.2f} seconds")
        return

    print(f"\nFlattening {len(to_flatten)} files via disconnect task:")
    for f in to_flatten:
        print(f"  {f['id']} (depth={f['depth']}) — {f['reason']}")

    task_map = {}
    for f in to_flatten:
        try:
            task_id = trigger_disconnect(f["id"])
            task_map[f["id"]] = task_id
            log(f"  Triggered disconnect for {f['id']}")
        except Exception as e:
            log(f"  FAILED to trigger disconnect for {f['id']}: {e}")

    if task_map:
        log(f"Waiting for {len(task_map)} disconnect tasks...")
        results = _launch_and_track_tasks(task_map, label="flatten")
        finished = sum(1 for s in results.values() if s == "finished")
        failed = sum(1 for s in results.values() if s != "finished")
        print(f"\nFlattened: {finished}, Failed: {failed}")

    log(f"Total execution time: {time()-t:.2f} seconds")


