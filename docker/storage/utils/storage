def cmd_desktops(args):
    """Dump every desktop with role, deployment, idle and size info.

    Output: desktops.tsv with one row per (domain, storage_id) pair:
        domain_id, name, kind, user, role, deployment_id, storage_id,
        storage_status, size_bytes, mtime_iso, accessed_iso, months_idle

    `months_idle` uses domains.accessed when available, else file mtime.
    Then prints a role × idle-bucket summary table.

    Read-only; no API writes, no file deletions.
    """
    from datetime import datetime
    from pathlib import Path

    from storage_lib.api import (
        fetch_domain_deployments,
        fetch_domains_accessed,
        fetch_storages,
    )

    out_dir = Path(args.output_dir) if args.output_dir else get_output_dir()
    out_dir.mkdir(parents=True, exist_ok=True)
    log(f"Writing desktops dump to {out_dir}")

    info = fetch_domain_deployments()
    domains = info["domains"]
    accessed_by_storage = fetch_domains_accessed()
    storages = fetch_storages() or []
    storage_status = {s["id"]: s.get("status", "unknown") for s in storages}
    storage_path = {s["id"]: s.get("path") for s in storages}
    storage_size = {
        s["id"]: (s.get("qemu-img-info") or {}).get("actual-size") or 0
        for s in storages
    }

    def _to_unix(v):
        if v is None or v == "":
            return None
        if isinstance(v, (int, float)):
            return int(v)
        try:
            return int(v)
        except (TypeError, ValueError):
            pass
        try:
            return int(
                datetime.fromisoformat(str(v).replace("Z", "+00:00")).timestamp()
            )
        except Exception:
            return None

    now = datetime.now()
    rows = []
    for did, d in domains.items():
        for sid in d.get("storage_ids") or [None]:
            acc = _to_unix(accessed_by_storage.get(sid)) if sid else None
            mtime_iso = ""
            mtime_ts = None
            p = storage_path.get(sid) if sid else None
            if p:
                try:
                    st = os.stat(p)
                    mtime_ts = int(st.st_mtime)
                    mtime_iso = datetime.fromtimestamp(st.st_mtime).isoformat(
                        timespec="seconds"
                    )
                except OSError:
                    pass
            ref_ts = acc or mtime_ts
            months_idle = (now.timestamp() - ref_ts) / (30 * 86400) if ref_ts else None
            acc_iso = (
                datetime.fromtimestamp(acc).isoformat(timespec="seconds") if acc else ""
            )
            kind_val = d.get("kind")
            if isinstance(kind_val, list):
                kind_val = ",".join(kind_val)
            rows.append(
                {
                    "domain_id": did,
                    "name": (d.get("name") or "").replace("\t", " "),
                    "kind": kind_val or "",
                    "user": d.get("user") or "",
                    "role": d.get("role") or "",
                    "deployment_id": d.get("tag") or "",
                    "storage_id": sid or "",
                    "storage_status": storage_status.get(sid, "") if sid else "",
                    "size_bytes": storage_size.get(sid, 0) if sid else 0,
                    "mtime_iso": mtime_iso,
                    "accessed_iso": acc_iso,
                    "months_idle": months_idle,
                }
            )

    out_path = out_dir / "desktops.tsv"
    cols = [
        "domain_id",
        "name",
        "kind",
        "user",
        "role",
        "deployment_id",
        "storage_id",
        "storage_status",
        "size_bytes",
        "mtime_iso",
        "accessed_iso",
        "months_idle",
    ]
    with open(out_path, "w") as f:
        f.write("\t".join(cols) + "\n")
        for r in rows:
            mi = f"{r['months_idle']:.1f}" if r["months_idle"] is not None else ""
            f.write(
                f"{r['domain_id']}\t{r['name']}\t{r['kind']}\t{r['user']}\t"
                f"{r['role']}\t{r['deployment_id']}\t{r['storage_id']}\t"
                f"{r['storage_status']}\t{r['size_bytes']}\t{r['mtime_iso']}\t"
                f"{r['accessed_iso']}\t{mi}\n"
            )

    # Summary: role × idle-bucket × (deployment vs not)
    cutoffs = args.cutoffs or [2, 3, 4, 6, 12, 24]
    roles = sorted({r["role"] or "(none)" for r in rows})
    print()
    print("=" * 78)
    print(f"Desktops dump: {len(rows)} (domain,storage) rows in {out_path}")
    print("=" * 78)
    for in_dep in (False, True):
        label = "DEPLOYMENT desktops" if in_dep else "NON-deployment desktops"
        sub = [
            r
            for r in rows
            if bool(r["deployment_id"]) == in_dep and r["months_idle"] is not None
        ]
        print(f"\n--- {label} ({len(sub)} entries with idle data) ---")
        header = f"{'role':<12} " + " ".join(f">{m:<3}mo (n,GB)" for m in cutoffs)
        print(header)
        for role in roles:
            line = f"{role:<12} "
            for m in cutoffs:
                bucket = [
                    r
                    for r in sub
                    if r["role"] == (role if role != "(none)" else "")
                    and r["months_idle"] > m
                ]
                sz = sum(r["size_bytes"] for r in bucket) / (1024**3)
                line += f"{len(bucket):>4}/{sz:>7.1f} "
            print(line)


# ─── recycler-audit subcommand ───────────────────────────────────────────────


def cmd_recycler_audit(args):
    """Audit whether the deployment auto-recycler is actually doing its job.

    Joins:
      - deployments      (domains.tag)
      - last access      (max(domains.accessed) per deployment)
      - storage status   (storages.status: ready / recycled / deleted / …)
      - configured rule  (unused_item_timeout.send_unused_deployments_to_recycle_bin)

    Writes two TSVs in --output-dir (or current report dir):
      - deployment_recycler_audit.tsv      (one row per deployment)
      - deployment_recycler_violations.tsv (deployments past cutoff with at
                                            least one ready storage)
    Empty deployments (zero domains tagged) are reported separately —
    the official cron's eq_join silently drops them.

    Read-only; no API writes, no file deletions.
    """
    from collections import defaultdict
    from datetime import datetime, timedelta
    from pathlib import Path

    from storage_lib.api import (
        fetch_domain_deployments,
        fetch_domains_accessed,
        fetch_storages,
        fetch_unused_item_timeouts,
    )

    out_dir = Path(args.output_dir) if args.output_dir else get_output_dir()
    out_dir.mkdir(parents=True, exist_ok=True)
    log(f"Writing recycler audit to {out_dir}")

    timeouts = fetch_unused_item_timeouts()
    configured = timeouts.get("send_unused_deployments_to_recycle_bin")
    if args.cutoff_months is not None:
        cutoff_months = args.cutoff_months
        cutoff_source = f"--cutoff-months={cutoff_months}"
    else:
        cutoff_months = configured
        cutoff_source = (
            f"unused_item_timeout.send_unused_deployments_to_recycle_bin={configured}"
        )

    info = fetch_domain_deployments()
    domains = info["domains"]  # domain_id -> {tag, storage_ids, ...}
    deployments = info["deployments"]  # deployment_id -> [domain_id, ...]

    accessed_by_storage = (
        fetch_domains_accessed()
    )  # storage_id -> accessed (unix int or iso)

    storages = fetch_storages() or []
    storage_status = {s["id"]: s.get("status", "unknown") for s in storages}
    storage_size = {
        s["id"]: (s.get("qemu-img-info") or {}).get("actual-size") or 0
        for s in storages
    }

    def _to_unix(v):
        if v is None or v == "":
            return None
        if isinstance(v, (int, float)):
            return int(v)
        try:
            return int(v)
        except (TypeError, ValueError):
            pass
        try:
            return int(
                datetime.fromisoformat(str(v).replace("Z", "+00:00")).timestamp()
            )
        except Exception:
            return None

    def _domain_max_accessed(domain_ids):
        best = None
        for did in domain_ids:
            for sid in domains.get(did, {}).get("storage_ids", []):
                ts = _to_unix(accessed_by_storage.get(sid))
                if ts is not None and (best is None or ts > best):
                    best = ts
        return best

    now = datetime.now()
    cutoff_ts = None
    if cutoff_months is not None:
        cutoff_ts = int((now - timedelta(days=cutoff_months * 30)).timestamp())

    audit_rows = []
    violations = []
    empty_deps = []

    for dep_id, domain_ids in deployments.items():
        max_acc = _domain_max_accessed(domain_ids)
        statuses = defaultdict(int)
        ready_size = 0
        for did in domain_ids:
            for sid in domains.get(did, {}).get("storage_ids", []):
                st = storage_status.get(sid, "missing_in_api")
                statuses[st] += 1
                if st == "ready":
                    ready_size += storage_size.get(sid, 0)
        months_idle = (now.timestamp() - max_acc) / (30 * 86400) if max_acc else None
        max_acc_iso = (
            datetime.fromtimestamp(max_acc).isoformat(timespec="seconds")
            if max_acc
            else ""
        )
        breakdown = ",".join(f"{k}={v}" for k, v in sorted(statuses.items())) or "-"
        row = {
            "deployment_id": dep_id,
            "desktop_count": len(domain_ids),
            "max_accessed_iso": max_acc_iso,
            "months_since_accessed": (
                f"{months_idle:.1f}" if months_idle is not None else ""
            ),
            "storage_status_breakdown": breakdown,
            "ready_size_gb": f"{ready_size / (1024**3):.2f}",
        }
        audit_rows.append(row)

        if (
            cutoff_ts is not None
            and max_acc is not None
            and max_acc < cutoff_ts
            and statuses.get("ready", 0) > 0
        ):
            violations.append(row)

    # Empty deployments: rows in `deployments` table with zero tagged domains.
    # The official cron's eq_join silently drops these so they live forever.
    try:
        from storage_lib.api import _get_api as _api_factory

        dep_rows = _api_factory().post(
            "/admin/table/deployments", data={"pluck": ["id", "name"]}, timeout=60
        )
        all_dep_ids = {d["id"]: d.get("name") for d in dep_rows if d.get("id")}
        for dep_id, name in all_dep_ids.items():
            if dep_id not in deployments:
                empty_deps.append({"deployment_id": dep_id, "name": name or ""})
    except Exception as e:
        log(f"WARNING: could not list deployments table for empty-check: {e}")

    audit_path = out_dir / "deployment_recycler_audit.tsv"
    with open(audit_path, "w") as f:
        f.write(
            "deployment_id\tdesktop_count\tmax_accessed_iso\t"
            "months_since_accessed\tstorage_status_breakdown\tready_size_gb\n"
        )
        for r in sorted(
            audit_rows,
            key=lambda x: float(x["months_since_accessed"] or -1),
            reverse=True,
        ):
            f.write(
                f"{r['deployment_id']}\t{r['desktop_count']}\t"
                f"{r['max_accessed_iso']}\t{r['months_since_accessed']}\t"
                f"{r['storage_status_breakdown']}\t{r['ready_size_gb']}\n"
            )

    viol_path = out_dir / "deployment_recycler_violations.tsv"
    with open(viol_path, "w") as f:
        f.write(
            "deployment_id\tdesktop_count\tmax_accessed_iso\t"
            "months_since_accessed\tstorage_status_breakdown\tready_size_gb\n"
        )
        for r in sorted(
            violations,
            key=lambda x: float(x["ready_size_gb"]),
            reverse=True,
        ):
            f.write(
                f"{r['deployment_id']}\t{r['desktop_count']}\t"
                f"{r['max_accessed_iso']}\t{r['months_since_accessed']}\t"
                f"{r['storage_status_breakdown']}\t{r['ready_size_gb']}\n"
            )

    empty_path = out_dir / "deployment_recycler_empty.tsv"
    with open(empty_path, "w") as f:
        f.write("deployment_id\tname\n")
        for r in empty_deps:
            f.write(f"{r['deployment_id']}\t{r['name']}\n")

    # Headline
    total_violation_size = sum(float(r["ready_size_gb"]) for r in violations)
    print()
    print("=" * 72)
    print("Deployment auto-recycler audit")
    print("=" * 72)
    print(f"Configured cutoff source : {cutoff_source}")
    print(
        f"Effective cutoff         : "
        + (
            f"{cutoff_months} months"
            if cutoff_months is not None
            else "DISABLED (None)"
        )
    )
    print(f"Deployments with desktops: {len(audit_rows)}")
    print(f"Empty deployments        : {len(empty_deps)}  (cron's eq_join skips these)")
    if cutoff_months is None:
        print()
        print("⚠ No cutoff configured — the recycler is a no-op by design.")
        print("  Set unused_item_timeout.send_unused_deployments_to_recycle_bin")
        print("  via the admin UI (value is in MONTHS).")
    else:
        print(
            f"Violations (>{cutoff_months}mo idle, ≥1 ready storage):"
            f" {len(violations)}  ({total_violation_size:.2f} GB)"
        )
        if violations:
            print()
            print("⚠ Recycler is NOT removing these deployments — see")
            print(f"  {viol_path}")
        else:
            print()
            print("✓ No violations — recycler appears to be working.")
    print()
    print("Files written:")
    print(f"  {audit_path}")
    print(f"  {viol_path}")
    print(f"  {empty_path}")


# ─── deployments subcommand ──────────────────────────────────────────────────


def cmd_deployments(args):
    """Annotate cleanup file lists with deployment ownership.

    For each `bad_*.txt` (or files matched by --filter) in the report
    directory, look up `Path(p).stem` as a storage_id, then check whether
    the API knows which domain/deployment that storage belongs to.

    Writes `<name>.deployments.tsv` per source list with columns:
        path, storage_id, domain_id, deployment_id
    Then prints a summary table: deployment_id → file count + size_GB,
    plus an "(unassigned)" row for files whose storage is not tagged
    (either storage_id unknown to API or domain has tag=None).
    """
    from collections import defaultdict
    from pathlib import Path

    from storage_lib.api import fetch_domain_deployments

    report_dir = Path(args.directory)
    if not report_dir.is_dir():
        print(f"ERROR: not a directory: {report_dir}")
        sys.exit(1)

    patterns = args.filter or ["bad_*.txt", "ok_no_derivatives.txt"]
    txt_files = []
    for pat in patterns:
        # accept both raw names and globs
        if "*" in pat or "?" in pat:
            txt_files.extend(sorted(report_dir.glob(pat)))
        else:
            p = report_dir / (pat if pat.endswith(".txt") else f"{pat}.txt")
            if p.exists():
                txt_files.append(p)
    txt_files = sorted(set(txt_files))
    txt_files = [p for p in txt_files if not p.name.endswith(".meta.tsv")]
    if not txt_files:
        print(f"No matching .txt files in {report_dir}")
        sys.exit(1)

    info = fetch_domain_deployments()
    s2d = info["storage_to_domain"]
    s2dep = info["storage_to_deployment"]
    s2role = info.get("storage_to_role", {})
    domains = info["domains"]

    def size_for(path):
        try:
            return os.stat(path).st_size
        except OSError:
            return 0

    overall = defaultdict(lambda: [0, 0])  # deployment_id -> [count, bytes]
    per_file = {}

    for tf in txt_files:
        local = defaultdict(lambda: [0, 0])
        out_path = report_dir / f"{tf.stem}.deployments.tsv"
        with open(tf) as src, open(out_path, "w") as dst:
            dst.write("path\tstorage_id\tdomain_id\tdeployment_id\trole\n")
            for line in src:
                p = line.strip()
                if not p:
                    continue
                sid = Path(p).stem
                did = s2d.get(sid, "")
                dep = s2dep.get(sid, "")
                role = s2role.get(sid, "")
                dst.write(f"{p}\t{sid}\t{did}\t{dep}\t{role}\n")
                key = dep or "(unassigned)"
                size = size_for(p)
                local[key][0] += 1
                local[key][1] += size
                overall[key][0] += 1
                overall[key][1] += size
        per_file[tf.name] = local

    def fmt_gb(b):
        return f"{b / (1024**3):.2f}"

    def render(title, data):
        print(f"\n=== {title} ===")
        print(f"{'deployment_id':<40} {'count':>8} {'size_GB':>12}")
        # Sort by total bytes desc, keep "(unassigned)" last
        keys = sorted(
            data.keys(),
            key=lambda k: (k == "(unassigned)", -data[k][1]),
        )
        total_c = total_b = 0
        for k in keys:
            c, b = data[k]
            total_c += c
            total_b += b
            print(f"{k:<40} {c:>8} {fmt_gb(b):>12}")
        print(f"{'TOTAL':<40} {total_c:>8} {fmt_gb(total_b):>12}")

    if args.per_file:
        for name, data in per_file.items():
            render(name, data)
    render("OVERALL by deployment", overall)


# ─── age-report subcommand ───────────────────────────────────────────────────


def cmd_age_report(args):
    """Aggregate size & count distribution from cleanup .meta.tsv sidecars."""
    from collections import defaultdict
    from datetime import datetime, timedelta
    from pathlib import Path

    report_dir = Path(args.directory)
    if not report_dir.is_dir():
        print(f"ERROR: not a directory: {report_dir}")
        sys.exit(1)

    patterns = args.filter or ["*.meta.tsv"]
    if not any("meta.tsv" in p for p in patterns):
        patterns = [
            p if p.endswith(".meta.tsv") else f"{Path(p).stem}.meta.tsv"
            for p in patterns
        ]

    meta_files = []
    for pat in patterns:
        meta_files.extend(sorted(report_dir.glob(pat)))
    meta_files = sorted(set(meta_files))
    if not meta_files:
        print(f"No .meta.tsv files matched in {report_dir}")
        sys.exit(1)

    def bucket_key(dt):
        if args.bucket == "day":
            return dt.strftime("%Y-%m-%d")
        if args.bucket == "week":
            iso = dt.isocalendar()
            return f"{iso[0]}-W{iso[1]:02d}"
        if args.bucket == "month":
            return dt.strftime("%Y-%m")
        if args.bucket == "year":
            return dt.strftime("%Y")
        raise ValueError(args.bucket)

    overall = defaultdict(lambda: [0, 0])  # bucket -> [count, size_bytes]
    per_file = {}

    for mf in meta_files:
        local = defaultdict(lambda: [0, 0])
        with open(mf) as f:
            header = f.readline()  # skip
            for line in f:
                parts = line.rstrip("\n").split("\t")
                if len(parts) < 3:
                    continue
                try:
                    size = int(parts[1])
                    mtime = datetime.fromisoformat(parts[2])
                except (ValueError, IndexError):
                    continue
                key = bucket_key(mtime)
                local[key][0] += 1
                local[key][1] += size
                overall[key][0] += 1
                overall[key][1] += size
        per_file[mf.name] = local

    def fmt_gb(b):
        return f"{b / (1024**3):.2f}"

    def render(title, data):
        print(f"\n=== {title} ===")
        print(f"{'bucket':<12} {'count':>10} {'size_GB':>12}")
        total_c = total_b = 0
        for key in sorted(data.keys()):
            c, b = data[key]
            total_c += c
            total_b += b
            print(f"{key:<12} {c:>10} {fmt_gb(b):>12}")
        print(f"{'TOTAL':<12} {total_c:>10} {fmt_gb(total_b):>12}")

    if args.per_file:
        for name, data in per_file.items():
            render(name, data)
    render(f"OVERALL ({args.bucket})", overall)


# ─── db-cleanup subcommand ───────────────────────────────────────────────────


def cmd_db_cleanup(args):
    """Detect and (with --apply) remove malformed `storage` rows.

    Three classes of bad rows are scanned:
      1. Zombie rows: only `id` field present, all other fields wiped. These
         are the residue of a `Storage(<unknown_id>)` call hitting the
         insert-on-construct bug in `RethinkBase.__init__`.
      2. Path-shaped ids: `id` is a filesystem path string instead of a UUID.
         Same root cause but the input was a parent path rather than a UUID.
      3. Path-shaped parents (reported only): the row's `parent` field
         points to a path string. Disk chains still work, but DB joins on
         `parent` break.

    A row is only deletable when no domain, no recycle_bin entry, and no
    other storage row references it. Each candidate is dumped to
    `db_cleanup_pending.jsonl` together with the result of the safety check.
    With `--apply`, after an explicit y/N confirmation, the verified rows
    are deleted from the storage table; the same JSONL serves as the audit
    record. Path-shaped-parent rows are *never* auto-deleted.
    """
    from storage_lib.db import (
        categorize_zombies,
        delete_storage_row,
        find_path_shaped_ids,
        find_storages_with_path_parent,
        find_zombie_storages,
        get_conn,
        is_storage_referenced,
    )

    output_dir = get_output_dir()
    log("=" * 60)
    log("DB CLEANUP — storage table malformed row scan")
    log("=" * 60)

    with get_conn() as conn:
        zombies = find_zombie_storages(conn)
        path_ids = find_path_shaped_ids(conn)
        path_parents = find_storages_with_path_parent(conn)

        # path-shaped ids and zombies overlap (a path-id row is also a zombie)
        # so dedupe by id.
        seen = set()
        all_candidates = []
        for row in zombies + path_ids:
            rid = row.get("id")
            if rid in seen:
                continue
            seen.add(rid)
            all_candidates.append(row)

        uuid_zombies, path_zombies, other = categorize_zombies(all_candidates)

        log(f"  Zombie rows (UUID-shaped id, no other fields): {len(uuid_zombies)}")
        log(f"  Path-shaped id rows:                           {len(path_zombies)}")
        log(f"  Other malformed (no path/uuid id):             {len(other)}")
        log(f"  Path-shaped `parent` field rows (REPORT-ONLY): {len(path_parents)}")

        # Classify each candidate by safety
        verified_safe = []
        unsafe = []
        for row in all_candidates:
            refs = is_storage_referenced(conn, row["id"])
            entry = dict(row)
            entry["_references"] = refs
            ref_total = (
                len(refs["by_domains"])
                + len(refs["by_recycle_bin"])
                + len(refs["by_storage_parent"])
            )
            if ref_total == 0:
                verified_safe.append(entry)
            else:
                unsafe.append(entry)

        log(f"  → safe to delete (no references):              {len(verified_safe)}")
        log(f"  → unsafe (still referenced — keep, investigate):{len(unsafe)}")

        # Dump JSONL outputs
        pending_path = output_dir / "db_cleanup_pending.jsonl"
        kept_path = output_dir / "db_cleanup_kept_referenced.jsonl"
        path_parent_path = output_dir / "db_cleanup_path_parents_review.jsonl"

        with open(pending_path, "w") as f:
            for e in verified_safe:
                f.write(json.dumps(e, sort_keys=True, default=str) + "\n")
        with open(kept_path, "w") as f:
            for e in unsafe:
                f.write(json.dumps(e, sort_keys=True, default=str) + "\n")
        with open(path_parent_path, "w") as f:
            for e in path_parents:
                f.write(json.dumps(e, sort_keys=True, default=str) + "\n")

        log(f"\n  Wrote: {pending_path}")
        log(f"  Wrote: {kept_path}")
        log(f"  Wrote: {path_parent_path}")

        if not args.apply:
            print()
            print("Read-only mode. Re-run with --apply to delete the verified rows.")
            print("Inspect the JSONL files above before running --apply.")
            return

        if not verified_safe:
            log("\nNothing to delete.")
            return

        if not args.yes:
            print()
            print(f"About to DELETE {len(verified_safe)} storage rows from the DB.")
            print(
                "Type 'yes' (literally) to confirm," " anything else aborts: ",
                end="",
                flush=True,
            )
            answer = sys.stdin.readline().strip()
            if answer != "yes":
                print("Aborted.")
                return

        deleted = 0
        delete_log_path = output_dir / "db_cleanup_deleted.jsonl"
        with open(delete_log_path, "w") as f:
            for entry in verified_safe:
                rid = entry["id"]
                # Re-verify references right before deletion (race-safety).
                refs_now = is_storage_referenced(conn, rid)
                if any(refs_now.values()):
                    log(f"  SKIP (newly referenced): {rid}")
                    continue
                resp = delete_storage_row(conn, rid)
                f.write(
                    json.dumps(
                        {**entry, "_delete_response": resp},
                        sort_keys=True,
                        default=str,
                    )
                    + "\n"
                )
                deleted += 1
        log(f"\nDeleted {deleted} rows. Audit log: {delete_log_path}")


# ─── sparsify subcommand ─────────────────────────────────────────────────────


def cmd_sparsify(args):
    """Thin wrapper that hands off to the standalone /utils/sparsify script.

    Kept as a subcommand so operators have a single CLI surface (`storage
    sparsify ...`) rather than remembering a separate util name. All flags
    after `sparsify` are forwarded verbatim to the script. Use `storage
    sparsify --help` (which forwards `-h`) to see the script's options.
    """
    import subprocess

    script_path = "/utils/sparsify"
    if not os.path.isfile(script_path):
        # Fall back to the script next to this file (dev/test environments).
        local = Path(__file__).resolve().parent / "sparsify"
        if local.is_file():
            script_path = str(local)
        else:
            log(f"ERROR: sparsify script not found at {script_path}")
            sys.exit(1)

    cmd = [script_path] + list(args.passthrough or [])
    log(f"Invoking: {' '.join(cmd)}")
    rc = subprocess.call(cmd)
    sys.exit(rc)


# ─── CLI argument parser ─────────────────────────────────────────────────────


def build_parser():
    parser = argparse.ArgumentParser(
        prog="storage",
        description="IsardVDI storage utility",
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # sizes
    p_sizes = subparsers.add_parser(
        "sizes",
        help="Report disk sizes by storage status (read-only)",
    )
    p_sizes.add_argument("path", help="Directory to scan")
    p_sizes.add_argument(
        "-e",
        "--extension",
        default="qcow2",
        help="File extension to filter (default: qcow2, use 'all' for no filter)",
    )
    p_sizes.add_argument(
        "--no-api",
        action="store_true",
        help="Skip API calls, show filesystem sizes only",
    )
    p_sizes.add_argument(
        "-o",
        "--output",
        help="Write raw per-file data to this CSV file",
    )
    p_sizes.add_argument(
        "--past-days",
        type=int,
        help="Split totals by last accessed time: recent (within N days) vs old",
    )
    p_sizes.add_argument(
        "--check-qcow2",
        action="store_true",
        help="Inspect each qcow2 with qemu-img info -U (backing chain, virtual size, corruption detection)",
    )
    p_sizes.set_defaults(func=cmd_sizes)

    # integrity
    p_integrity = subparsers.add_parser(
        "integrity",
        help="Check qcow2 integrity and analyze dependencies",
    )
    p_integrity.add_argument(
        "--compare-sizes",
        action="store_true",
        help="Compare API qemu-img-info.actual-size with real file sizes",
    )
    p_integrity.add_argument(
        "--threshold",
        type=float,
        default=0.1,
        help="Size difference threshold in GB for reporting discrepancies (default: 0.1)",
    )
    p_integrity.set_defaults(func=cmd_integrity)

    # cleanup
    p_cleanup = subparsers.add_parser(
        "cleanup",
        help="Generate deletion file lists for orphaned/broken storage",
    )
    p_cleanup.add_argument(
        "--move",
        action="store_true",
        help="Move deletable files to /isard/volatile/to_delete/ instead of just listing them",
    )
    p_cleanup.add_argument(
        "--interactive",
        action="store_true",
        help=(
            "When combined with --move, walk through deletable buckets from"
            " safest to least safe, showing counts and a sample for each and"
            " prompting before moving. Templates are offered as a sub-prompt"
            " inside each bucket; --include-templates is ignored in this mode."
        ),
    )
    p_cleanup.add_argument(
        "--include-templates",
        action="store_true",
        help="Also move template files (by default templates are skipped for safety)",
    )
    p_cleanup.add_argument(
        "--compare-sizes",
        action="store_true",
        help="Also compare API qemu-img-info.actual-size with real file sizes",
    )
    p_cleanup.add_argument(
        "--threshold",
        type=float,
        default=0.1,
        help="Size difference threshold in GB (default: 0.1)",
    )
    p_cleanup.add_argument(
        "--rescan",
        action="store_true",
        help=(
            "Ignore the persistent qcow chain cache and re-run qemu-img on"
            " every file. The cache is still rewritten with fresh data for"
            " future runs. Default: read cache when available."
        ),
    )
    p_cleanup.set_defaults(func=cmd_cleanup)

    # by-role
    p_role = subparsers.add_parser(
        "by-role",
        help="Report storage grouped by user role",
    )
    p_role.add_argument(
        "--base-path",
        default="/logs",
        help="Base path for output (default: /logs)",
    )
    p_role.set_defaults(func=cmd_by_role)

    # repair-chains
    p_repair = subparsers.add_parser(
        "repair-chains",
        help="Diagnose and optionally fix broken backing chains",
    )
    p_repair.add_argument(
        "--fix",
        action="store_true",
        help="Apply fixes (qemu-img rebase) for recoverable broken chains",
    )
    p_repair.add_argument(
        "--include-templates",
        action="store_true",
        help="Also fix template files (by default templates are never modified)",
    )
    p_repair.set_defaults(func=cmd_repair_chains)

    # full-cleanup
    p_full = subparsers.add_parser(
        "full-cleanup",
        help="Full maintenance: verify, repair chains, move unusable files",
    )
    p_full.add_argument(
        "--include-templates",
        action="store_true",
        help="Also repair/move template files (by default templates are skipped)",
    )
    p_full.add_argument(
        "--sparsify",
        action="store_true",
        help="Run virt-sparsify --in-place on movable files before moving (reclaim space)",
    )
    p_full.add_argument(
        "--compress",
        action="store_true",
        help="Compress qcow2 files (qemu-img convert -c) before moving",
    )
    p_full.add_argument(
        "--rescan",
        action="store_true",
        help=(
            "Ignore the persistent qcow chain cache and re-run qemu-img on"
            " every file. The cache is still rewritten with fresh data for"
            " future runs. Default: read cache when available."
        ),
    )
    p_full.add_argument(
        "--dry-run",
        action="store_true",
        help=(
            "Do not modify anything: skip chain repairs, sparsify/compress,"
            " and the move-to-to_delete step. Always writes the file lists"
            " plus a dry_run_actions.md describing every action that would"
            " be taken and why."
        ),
    )
    p_full.set_defaults(func=cmd_full_cleanup)

    # verify
    p_verify = subparsers.add_parser(
        "verify",
        help="Check DB-vs-disk consistency and optionally fix path mismatches",
    )
    p_verify.add_argument(
        "--fix",
        action="store_true",
        help="Fix issues: update DB paths for mismatched files, trigger find for missing/ghost",
    )
    p_verify.set_defaults(func=cmd_verify)

    # recover
    p_recover = subparsers.add_parser(
        "recover",
        help="Recover failed desktops by recreating missing incremental disks",
    )
    p_recover.add_argument(
        "--fix",
        action="store_true",
        help="Create missing disks and trigger find tasks to restore desktops",
    )
    p_recover.set_defaults(func=cmd_recover)

    # chains
    p_chains = subparsers.add_parser(
        "chains",
        help="Analyze backing chain depth and optionally flatten deep/single-dependent chains",
    )
    p_chains.add_argument(
        "--max-depth",
        type=int,
        default=3,
        help="Flag chains deeper than this threshold (default: 3)",
    )
    p_chains.add_argument(
        "--flatten-singles",
        action="store_true",
        help="Disconnect single-dependent intermediate templates (flatten child)",
    )
    p_chains.add_argument(
        "--flatten-deep",
        type=int,
        metavar="N",
        help="Disconnect leaf files deeper than N (flatten to depth 0)",
    )
    p_chains.add_argument(
        "--include-templates",
        action="store_true",
        help="Also flatten template files (by default templates are skipped)",
    )
    p_chains.add_argument(
        "--verbose",
        action="store_true",
        help="Show all chain trees (by default shows top 10)",
    )
    p_chains.set_defaults(func=cmd_chains)

    # age-report
    p_age = subparsers.add_parser(
        "age-report",
        help="Aggregate size & count from cleanup .meta.tsv sidecars by day/week/month/year",
    )
    p_age.add_argument(
        "directory",
        help="Path to a cleanup report directory (contains *.meta.tsv files)",
    )
    p_age.add_argument(
        "--bucket",
        choices=["day", "week", "month", "year"],
        default="month",
        help="Aggregation granularity (default: month)",
    )
    p_age.add_argument(
        "--filter",
        action="append",
        metavar="NAME",
        help=(
            "Restrict to specific lists (e.g. bad_deletable_orphans or"
            " ok_no_derivatives). Repeatable. Default: all *.meta.tsv."
        ),
    )
    p_age.add_argument(
        "--per-file",
        action="store_true",
        help="Also print a separate breakdown per source list",
    )
    p_age.set_defaults(func=cmd_age_report)

    # deployments
    p_dep = subparsers.add_parser(
        "deployments",
        help="Annotate cleanup file lists with the deployment each storage belongs to",
    )
    p_dep.add_argument(
        "directory",
        help="Path to a cleanup report directory (containing bad_*.txt etc.)",
    )
    p_dep.add_argument(
        "--filter",
        action="append",
        metavar="NAME",
        help=(
            "Restrict to specific lists (e.g. bad_deletable_orphans). Repeatable."
            " Default: bad_*.txt + ok_no_derivatives.txt."
        ),
    )
    p_dep.add_argument(
        "--per-file",
        action="store_true",
        help="Also print a separate deployment breakdown per source list",
    )
    p_dep.set_defaults(func=cmd_deployments)

    # recycler-audit
    p_aud = subparsers.add_parser(
        "recycler-audit",
        help="Confirm whether the deployment auto-recycler is actually working",
    )
    p_aud.add_argument(
        "--cutoff-months",
        type=float,
        default=None,
        help=(
            "Override cutoff in months. Default: read from"
            " unused_item_timeout.send_unused_deployments_to_recycle_bin."
        ),
    )
    p_aud.add_argument(
        "--output-dir",
        default=None,
        help="Where to write the TSVs. Default: new timestamped /logs/analyze/<ts>",
    )
    p_aud.set_defaults(func=cmd_recycler_audit)

    # desktops
    p_desk = subparsers.add_parser(
        "desktops",
        help="Dump every desktop with role, deployment, idle and size info",
    )
    p_desk.add_argument(
        "--output-dir",
        default=None,
        help="Where to write desktops.tsv. Default: new timestamped /logs/analyze/<ts>",
    )
    p_desk.add_argument(
        "--cutoffs",
        type=lambda s: [float(x) for x in s.split(",")],
        default=None,
        help="Idle thresholds in months for the summary (default: 2,3,4,6,12,24)",
    )
    p_desk.set_defaults(func=cmd_desktops)

    # db-cleanup
    p_db = subparsers.add_parser(
        "db-cleanup",
        help=(
            "Detect and (with --apply) remove malformed storage table rows"
            " (zombie rows, path-shaped ids). Reports path-shaped `parent`"
            " fields without modifying them."
        ),
    )
    p_db.add_argument(
        "--apply",
        action="store_true",
        help="Actually delete the verified-safe rows (default: report only).",
    )
    p_db.add_argument(
        "-y",
        "--yes",
        action="store_true",
        help="Skip the confirmation prompt when --apply is set (CI use only).",
    )
    p_db.set_defaults(func=cmd_db_cleanup)

    # sparsify (thin wrapper around the standalone /utils/sparsify script)
    p_sparsify = subparsers.add_parser(
        "sparsify",
        help=(
            "Sparsify qcow2 files in-place using virt-sparsify (forwards all"
            " flags to the standalone /utils/sparsify script)."
        ),
        add_help=False,
    )
    p_sparsify.add_argument(
        "passthrough",
        nargs=argparse.REMAINDER,
        help="Arguments forwarded verbatim to /utils/sparsify",
    )
    p_sparsify.set_defaults(func=cmd_sparsify)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()
