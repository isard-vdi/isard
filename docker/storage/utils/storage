def build_parser():
    parser = argparse.ArgumentParser(
        prog="storage",
        description="IsardVDI storage utility",
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # sizes
    p_sizes = subparsers.add_parser(
        "sizes",
        help="Report disk sizes by storage status (read-only)",
    )
    p_sizes.add_argument("path", help="Directory to scan")
    p_sizes.add_argument(
        "-e",
        "--extension",
        default="qcow2",
        help="File extension to filter (default: qcow2, use 'all' for no filter)",
    )
    p_sizes.add_argument(
        "--no-api",
        action="store_true",
        help="Skip API calls, show filesystem sizes only",
    )
    p_sizes.add_argument(
        "-o",
        "--output",
        help="Write raw per-file data to this CSV file",
    )
    p_sizes.add_argument(
        "--past-days",
        type=int,
        help="Split totals by last accessed time: recent (within N days) vs old",
    )
    p_sizes.add_argument(
        "--check-qcow2",
        action="store_true",
        help="Inspect each qcow2 with qemu-img info -U (backing chain, virtual size, corruption detection)",
    )
    p_sizes.set_defaults(func=cmd_sizes)

    # integrity
    p_integrity = subparsers.add_parser(
        "integrity",
        help="Check qcow2 integrity and analyze dependencies",
    )
    p_integrity.add_argument(
        "--compare-sizes",
        action="store_true",
        help="Compare API qemu-img-info.actual-size with real file sizes",
    )
    p_integrity.add_argument(
        "--threshold",
        type=float,
        default=0.1,
        help="Size difference threshold in GB for reporting discrepancies (default: 0.1)",
    )
    p_integrity.set_defaults(func=cmd_integrity)

    # cleanup
    p_cleanup = subparsers.add_parser(
        "cleanup",
        help="Generate deletion file lists for orphaned/broken storage",
    )
    p_cleanup.add_argument(
        "--move",
        action="store_true",
        help="Move deletable files to /isard/volatile/to_delete/ instead of just listing them",
    )
    p_cleanup.add_argument(
        "--include-templates",
        action="store_true",
        help="Also move template files (by default templates are skipped for safety)",
    )
    p_cleanup.add_argument(
        "--compare-sizes",
        action="store_true",
        help="Also compare API qemu-img-info.actual-size with real file sizes",
    )
    p_cleanup.add_argument(
        "--threshold",
        type=float,
        default=0.1,
        help="Size difference threshold in GB (default: 0.1)",
    )
    p_cleanup.set_defaults(func=cmd_cleanup)

    # by-role
    p_role = subparsers.add_parser(
        "by-role",
        help="Report storage grouped by user role",
    )
    p_role.add_argument(
        "--base-path",
        default="/logs",
        help="Base path for output (default: /logs)",
    )
    p_role.set_defaults(func=cmd_by_role)

    # repair-chains
    p_repair = subparsers.add_parser(
        "repair-chains",
        help="Diagnose and optionally fix broken backing chains",
    )
    p_repair.add_argument(
        "--fix",
        action="store_true",
        help="Apply fixes (qemu-img rebase) for recoverable broken chains",
    )
    p_repair.add_argument(
        "--include-templates",
        action="store_true",
        help="Also fix template files (by default templates are never modified)",
    )
    p_repair.set_defaults(func=cmd_repair_chains)

    # full-cleanup
    p_full = subparsers.add_parser(
        "full-cleanup",
        help="Full maintenance: verify, repair chains, move unusable files",
    )
    p_full.add_argument(
        "--include-templates",
        action="store_true",
        help="Also repair/move template files (by default templates are skipped)",
    )
    p_full.add_argument(
        "--sparsify",
        action="store_true",
        help="Run virt-sparsify --in-place on movable files before moving (reclaim space)",
    )
    p_full.add_argument(
        "--compress",
        action="store_true",
        help="Compress qcow2 files (qemu-img convert -c) before moving",
    )
    p_full.set_defaults(func=cmd_full_cleanup)

    # verify
    p_verify = subparsers.add_parser(
        "verify",
        help="Check DB-vs-disk consistency and optionally fix path mismatches",
    )
    p_verify.add_argument(
        "--fix",
        action="store_true",
        help="Fix issues: update DB paths for mismatched files, trigger find for missing/ghost",
    )
    p_verify.set_defaults(func=cmd_verify)

    # recover
    p_recover = subparsers.add_parser(
        "recover",
        help="Recover failed desktops by recreating missing incremental disks",
    )
    p_recover.add_argument(
        "--fix",
        action="store_true",
        help="Create missing disks and trigger find tasks to restore desktops",
    )
    p_recover.set_defaults(func=cmd_recover)

    # chains
    p_chains = subparsers.add_parser(
        "chains",
        help="Analyze backing chain depth and optionally flatten deep/single-dependent chains",
    )
    p_chains.add_argument(
        "--max-depth",
        type=int,
        default=3,
        help="Flag chains deeper than this threshold (default: 3)",
    )
    p_chains.add_argument(
        "--flatten-singles",
        action="store_true",
        help="Disconnect single-dependent intermediate templates (flatten child)",
    )
    p_chains.add_argument(
        "--flatten-deep",
        type=int,
        metavar="N",
        help="Disconnect leaf files deeper than N (flatten to depth 0)",
    )
    p_chains.add_argument(
        "--include-templates",
        action="store_true",
        help="Also flatten template files (by default templates are skipped)",
    )
    p_chains.add_argument(
        "--verbose",
        action="store_true",
        help="Show all chain trees (by default shows top 10)",
    )
    p_chains.set_defaults(func=cmd_chains)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()
