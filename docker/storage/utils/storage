def _is_valid_storage(storage):
    """Check if a storage is valid and update its actual size from qemu-img info."""
    import json
    import subprocess

    path = storage["path"]
    if not path.endswith(".qcow2"):
        return None
    try:
        result = subprocess.run(
            ["qemu-img", "info", "--output=json", "-U", "--backing-chain", path],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        info = json.loads(result.stdout)
        if isinstance(info, list):
            actual_size = info[0].get("actual-size", 0)
        else:
            actual_size = info.get("actual-size", 0)
        storage["actual-size"] = actual_size
        return storage
    except Exception:
        return None


def _validate_storages(storages):
    """Validate storages in parallel. Returns (valid, invalid) lists."""
    import concurrent.futures

    valid = []
    invalid = []
    with concurrent.futures.ThreadPoolExecutor() as executor:
        futures = {
            executor.submit(_is_valid_storage, s): s for s in storages
        }
        for future in concurrent.futures.as_completed(futures):
            storage = futures[future]
            result = future.result()
            if result:
                valid.append(result)
            else:
                invalid.append(storage)
    return valid, invalid


def cmd_by_role(args):
    """Generate storage reports grouped by user role."""
    roles = ["advanced", "manager", "admin"]
    start_time = datetime.datetime.now()

    logs_path = os.path.join(args.base_path, "disks-by-role")
    os.makedirs(logs_path, exist_ok=True)

    print(
        f"[{start_time.strftime('%Y-%m-%d %H:%M:%S')}]"
        f" Starting storage reports by role - Output: {logs_path}"
    )

    resume = []
    for role in roles:
        role_start = datetime.datetime.now()

        storages = fetch_storages_by_role(role)
        valid_list, invalid_list = _validate_storages(storages)

        total_size = sum(s.get("actual-size", 0) for s in valid_list)

        role_elapsed = datetime.datetime.now() - role_start
        print(
            f"[{role_start.strftime('%H:%M:%S')}] {role}:"
            f" {len(storages)} total, {len(valid_list)} valid"
            f" ({format_size(total_size)}),"
            f" {len(invalid_list)} invalid"
            f" - {role_elapsed.total_seconds():.1f}s"
        )

        # Save invalid list
        invalid_path = os.path.join(logs_path, f"invalid_storages_{role}.list")
        with open(invalid_path, "w") as f:
            f.write(
                "\n".join(s["path"] for s in invalid_list) + "\n"
            )

        # Save valid list
        valid_path = os.path.join(logs_path, f"{role}_storages.list")
        with open(valid_path, "w") as f:
            f.write(
                "\n".join(s["path"] for s in valid_list) + "\n"
            )

        # Generate markdown report
        md_lines, resume_lines = _generate_role_report(
            valid_list, role, logs_path
        )
        resume.extend(resume_lines)

    end_time = datetime.datetime.now()
    total_elapsed = end_time - start_time

    print(
        f"[{end_time.strftime('%Y-%m-%d %H:%M:%S')}]"
        f" Completed in {total_elapsed.total_seconds():.1f}s"
        f" - Reports: {logs_path}"
    )

    if resume:
        print("Summary:")
        for line in resume:
            if line.startswith("# Storage Report") or line.startswith("- **"):
                print(f"  {line}")
            if line.startswith("---"):
                break


def _generate_role_report(storages, role, logs_path):
    """Generate markdown report for a role. Returns (md_lines, resume_lines)."""
    if not storages:
        print(f"No storages found for role '{role}'.")
        return [], []

    count = len(storages)
    total_size = 0
    oldest = None
    newest = None
    details = []

    for storage in storages:
        dt_str = storage.get("datetime", "")
        path = storage.get("path", "")
        actual_size = storage.get("actual-size", 0) or 0
        total_size += actual_size

        try:
            dt_obj = (
                datetime.datetime.strptime(dt_str, "%Y-%m-%d %H:%M:%S")
                if dt_str
                else None
            )
        except Exception:
            dt_obj = None

        if dt_obj:
            if not oldest or dt_obj < oldest[0]:
                oldest = (dt_obj, path)
            if not newest or dt_obj > newest[0]:
                newest = (dt_obj, path)

        details.append((dt_str, path, actual_size))

    md_lines = []
    md_lines.append(f"# Storage Report for Role: `{role}`\n")
    md_lines.append("## Summary")
    md_lines.append(f"- **Count:** {count}")
    md_lines.append(f"- **Total actual size:** {total_size / (1024**3):.2f} GiB")
    if oldest:
        md_lines.append(
            f"- **Oldest:** {oldest[0].strftime('%Y-%m-%d %H:%M:%S')}"
            f" - `{oldest[1]}`"
        )
    if newest:
        md_lines.append(
            f"- **Newest:** {newest[0].strftime('%Y-%m-%d %H:%M:%S')}"
            f" - `{newest[1]}`"
        )

    resume_lines = md_lines.copy()

    md_lines.append("\n## Details\n")
    md_lines.append("| DATETIME             | ACTUAL-SIZE (GiB) | PATH |")
    md_lines.append("|----------------------|-------------------|------|")
    for dt_str, path, actual_size in details:
        md_lines.append(
            f"| {dt_str:20} | {actual_size / (1024**3):17.2f} | `{path}` |"
        )

    md_report = "\n".join(md_lines)
    md_filename = os.path.join(logs_path, f"{role}_storages.md")
    with open(md_filename, "w") as f:
        f.write(md_report)

    return md_lines, resume_lines


