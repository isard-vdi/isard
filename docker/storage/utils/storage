# ─── sizes subcommand ────────────────────────────────────────────────────────

CATEGORIES = ["active", "recycled", "other"]


def classify(storage_info):
    """Classify a storage entry into: active, recycled, or other."""
    if storage_info is None:
        return "other"
    if storage_info["has_domains"]:
        return "active"
    if storage_info["status"] == "recycled":
        return "recycled"
    return "other"


def _empty_counts():
    return {"size": 0, "count": 0}


def _empty_breakdown():
    return {cat: _empty_counts() for cat in CATEGORIES}


def _empty_time_split():
    return {
        "recent": _empty_breakdown(),
        "old": _empty_breakdown(),
        "recent_total": _empty_counts(),
        "old_total": _empty_counts(),
    }


def _add_to(breakdown, category, size):
    breakdown[category]["size"] += size
    breakdown[category]["count"] += 1


def _add_to_counts(counts, size):
    counts["size"] += size
    counts["count"] += 1


def _print_breakdown(breakdown, indent=""):
    labels = {
        "active": "Active (has domains)",
        "recycled": "Recycled",
        "other": "Other",
    }
    for cat in CATEGORIES:
        c = breakdown[cat]
        if c["count"] == 0:
            continue
        print(
            f"{indent}{labels[cat]:<24} {c['count']:>6} files"
            f"  {format_size(c['size']):>10}"
        )


def _print_time_split(split, cutoff_date, indent=""):
    recent_label = f"Last accessed >= {cutoff_date.strftime('%Y-%m-%d')}"
    old_label = f"Last accessed < {cutoff_date.strftime('%Y-%m-%d')}"

    r = split["recent_total"]
    o = split["old_total"]
    if r["count"]:
        print(f"{indent}{recent_label}:")
        print(
            f"{indent}  {'Total':<22} {r['count']:>6} files"
            f"  {format_size(r['size']):>10}"
        )
        _print_breakdown(split["recent"], indent=indent + "  ")
    if o["count"]:
        print(f"{indent}{old_label}:")
        print(
            f"{indent}  {'Total':<22} {o['count']:>6} files"
            f"  {format_size(o['size']):>10}"
        )
        _print_breakdown(split["old"], indent=indent + "  ")


def cmd_sizes(args):
    """Report disk sizes by storage status (read-only)."""
    log("Starting sizes report (read-only)")
    if args.no_api:
        log("API calls disabled (--no-api)")

    ext = None if args.extension == "all" else args.extension

    storage_lookup = None
    domain_accessed = None
    cutoff_date = None

    if not args.no_api:
        storage_lookup = fetch_storage_lookup()
        if args.output or args.past_days:
            domain_accessed = fetch_domains_accessed()

    if args.past_days:
        if args.no_api:
            log(
                "WARNING: --past-days requires API data, ignoring (use without --no-api)"
            )
        else:
            cutoff_date = datetime.datetime.now() - datetime.timedelta(
                days=args.past_days
            )
            log(
                f"Time split cutoff: {cutoff_date.strftime('%Y-%m-%d')}"
                f" ({args.past_days} days ago)"
            )

    # Scan files
    all_files = scan_files(args.path, ext)

    if args.check_qcow2:
        qcow2_count = sum(1 for f in all_files if f.suffix == ".qcow2")
        log(
            f"qcow2 inspection enabled: {qcow2_count} qcow2 files to inspect"
            " with qemu-img info -U..."
        )
    if cutoff_date:
        log(f"Time split cutoff: {cutoff_date.strftime('%Y-%m-%d')} (--past-days)")

    # Process files
    totals = _empty_breakdown()
    total_size = 0
    total_files = 0
    total_corrupted = 0
    total_inspected = 0
    dirs = {}
    raw_rows = []
    time_totals = _empty_time_split() if cutoff_date else None
    file_count = len(all_files)

    cutoff_iso = cutoff_date.isoformat() if cutoff_date else None

    log("Scanning...")
    start = time()
    last_log = start

    for f in all_files:
        try:
            stat = f.stat()
            size = stat.st_size
            file_mtime = datetime.datetime.fromtimestamp(stat.st_mtime).isoformat()
        except OSError as e:
            log(f"WARNING: cannot stat {f}: {e}")
            continue

        total_size += size
        total_files += 1

        # Progress log
        now = time()
        if now - last_log >= 10:
            pct = (total_files / file_count * 100) if file_count else 0
            elapsed = now - start
            rate = total_files / elapsed if elapsed > 0 else 0
            remaining = (file_count - total_files) / rate if rate > 0 else 0
            msg = (
                f"  {total_files}/{file_count} ({pct:.0f}%) | {format_size(total_size)}"
            )
            if args.check_qcow2:
                msg += (
                    f" | inspected {total_inspected} qcow2,"
                    f" {total_corrupted} corrupted"
                )
            msg += f" | ~{remaining:.0f}s remaining"
            log(msg)
            last_log = now

        # qcow2 inspection
        backing_file = ""
        backing_file_id = ""
        virtual_size = ""
        qcow2_valid = ""
        is_qcow2 = f.suffix == ".qcow2"
        if args.check_qcow2 and is_qcow2:
            total_inspected += 1
            qinfo = qemu_img_info(f)
            if qinfo is None:
                qcow2_valid = "corrupted"
                total_corrupted += 1
            else:
                qcow2_valid = "ok"
                backing_file = (
                    qinfo.get("backing-filename")
                    or qinfo.get("full-backing-filename")
                    or ""
                )
                virtual_size = str(qinfo.get("virtual-size", ""))
                if backing_file:
                    try:
                        backing_file_id = Path(backing_file).stem
                    except Exception:
                        backing_file_id = ""

        # Classify
        storage_id = f.stem
        cat = None
        db_status = ""
        if storage_lookup is not None:
            info = storage_lookup.get(storage_id)
            if qcow2_valid == "corrupted":
                cat = "other"
                _add_to(totals, cat, size)
                db_status = info["status"] if info else ""
            else:
                cat = classify(info)
                _add_to(totals, cat, size)
                db_status = info["status"] if info else ""

        # Domain accessed time
        accessed = ""
        if domain_accessed is not None:
            accessed = domain_accessed.get(storage_id, "") or ""

        # Time split
        if cutoff_date and cat:
            ref_time = file_mtime if file_mtime else accessed
            bucket = "recent" if ref_time >= cutoff_iso else "old"
            _add_to(time_totals[bucket], cat, size)
            _add_to_counts(time_totals[f"{bucket}_total"], size)

        # Raw row for CSV
        if args.output:
            raw_rows.append(
                {
                    "file_path": str(f),
                    "storage_id": storage_id,
                    "size_bytes": size,
                    "size_human": format_size(size),
                    "virtual_size": virtual_size,
                    "file_mtime": file_mtime,
                    "category": cat or "",
                    "db_status": db_status,
                    "domain_accessed": accessed,
                    "qcow2_valid": qcow2_valid,
                    "backing_file": backing_file,
                    "backing_file_id": backing_file_id,
                }
            )

        # Per-directory
        parent = str(f.parent)
        if parent not in dirs:
            dirs[parent] = {
                "size": 0,
                "count": 0,
                "corrupted": 0,
                "breakdown": _empty_breakdown(),
                "time_split": _empty_time_split() if cutoff_date else None,
            }
        dirs[parent]["size"] += size
        dirs[parent]["count"] += 1
        if qcow2_valid == "corrupted":
            dirs[parent]["corrupted"] += 1
        if cat:
            _add_to(dirs[parent]["breakdown"], cat, size)
            if cutoff_date:
                _add_to(dirs[parent]["time_split"][bucket], cat, size)
                _add_to_counts(dirs[parent]["time_split"][f"{bucket}_total"], size)

    elapsed = time() - start
    log(
        f"Scan complete: {total_files} files in {len(dirs)} directories ({elapsed:.1f}s)"
    )
    if args.check_qcow2:
        log(f"Corrupted/invalid qcow2 files: {total_corrupted}")

    # Write CSV
    if args.output and raw_rows:
        log(f"Writing raw data to {args.output} ({len(raw_rows)} rows)...")
        fieldnames = [
            "file_path",
            "storage_id",
            "size_bytes",
            "size_human",
            "virtual_size",
            "file_mtime",
            "category",
            "db_status",
            "domain_accessed",
            "qcow2_valid",
            "backing_file",
            "backing_file_id",
        ]
        with open(args.output, "w", newline="") as fh:
            writer = csv.DictWriter(fh, fieldnames=fieldnames)
            writer.writeheader()
            writer.writerows(raw_rows)
        log(f"Raw data written to {args.output}")

    # Print totals
    print()
    print(f"Path: {args.path}")
    if ext:
        print(f"Filter: *.{ext}")
    print(f"Total files: {total_files}")
    print(f"Total size:  {format_size(total_size)}")
    if args.check_qcow2:
        print(f"Corrupted:   {total_corrupted}")

    if storage_lookup is not None:
        print()
        _print_breakdown(totals, indent="  ")

        if time_totals:
            print()
            _print_time_split(time_totals, cutoff_date, indent="  ")

    # Per-directory
    if dirs:
        print()
        header = f"{'Count':>6}  {'Size':>10}"
        if args.check_qcow2:
            header += f"  {'Bad':>4}"
        header += "  Directory"
        print(header)
        print("-" * 70)
        for d in sorted(dirs, key=lambda k: dirs[k]["size"], reverse=True):
            dinfo = dirs[d]
            line = f"{dinfo['count']:>6}  {format_size(dinfo['size']):>10}"
            if args.check_qcow2:
                line += f"  {dinfo['corrupted']:>4}"
            line += f"  {d}"
            print(line)
            if storage_lookup is not None:
                _print_breakdown(dinfo["breakdown"], indent="        ")
                if dinfo["time_split"]:
                    _print_time_split(
                        dinfo["time_split"], cutoff_date, indent="        "
                    )

    log("Done")


# ─── integrity subcommand ────────────────────────────────────────────────────


def cmd_integrity(args):
    """Check qcow2 integrity, dependencies, and DB-vs-disk consistency."""
    from tabulate import tabulate

    t = time()
    log("Starting integrity analysis...")

    # ── Fetch full API data ───────────────────────────────────────────────
    log("Getting storages from API...")
    raw_storages = fetch_storages()
    if raw_storages is None:
        log("ERROR: API call failed.")
        sys.exit(1)

    db_paths = [s["path"] for s in raw_storages]
    db_storage_lookup = {}
    for s in raw_storages:
        db_storage_lookup[s["path"]] = {
            "id": s["id"],
            "status": s.get("status", "unknown"),
            "has_domains": s.get("domains", 0) > 0,
        }
    log(f" - Got {len(db_paths)} storages from API in {time()-t:.2f} seconds")

    # ── Scan filesystem ───────────────────────────────────────────────────
    log("Getting storages from system...")
    sys_storages = scan_isard_dirs()
    log(f" - Got {len(sys_storages)} storages from system in {time()-t:.2f} seconds")

    qcow_storages = [s for s in sys_storages if s.endswith(".qcow2")]
    non_qcow_storages = [s for s in sys_storages if not s.endswith(".qcow2")]
    storages_in_db_not_in_system = set(db_paths) - set(qcow_storages)
    storages_in_system_not_in_db = set(qcow_storages) - set(db_paths)

    # ── Integrity & dependency checks ─────────────────────────────────────
    log("Analyzing qcow integrity + dependencies...")
    broken_chain, qcow_deps, _ = analyze_integrity_and_dependencies(qcow_storages)
    log(f" - Analyzed qcow integrity + dependencies in {time()-t:.2f} seconds")

    volatile = get_volatile_storages()
    deletable = set(qcow_deps["wo_derivatives"]) & storages_in_system_not_in_db

    # Classify non-qcow2 and duplicate files
    dead_artifacts, unknown_non_qcow = _classify_non_qcow2_files(
        non_qcow_storages, qcow_deps, db_storage_lookup=db_storage_lookup
    )
    duplicate_uploads = _find_duplicate_uploads(qcow_storages, db_storage_lookup)

    # ── Filesystem summary table ──────────────────────────────────────────
    log(f"Finished in {time()-t:.2f} seconds, generating report...")

    print("\n" + "=" * 70)
    print("FILESYSTEM ANALYSIS")
    print("=" * 70)

    table_data = [
        ["Info", "Count", "Size (GB)"],
        ["Storages in API", len(db_paths), "-"],
        ["Storages in system", len(sys_storages), size_gb(sys_storages)],
        ["Non-qcow2 files", len(non_qcow_storages), size_gb(non_qcow_storages)],
        [
            "Storages in API not in system",
            len(storages_in_db_not_in_system),
            "-",
        ],
        [
            "Storages in system not in API",
            len(storages_in_system_not_in_db),
            size_gb(storages_in_system_not_in_db),
        ],
        ["Broken chain", len(broken_chain), size_gb(broken_chain)],
        [
            "No backing file",
            len(qcow_deps["wo_backing"]),
            size_gb(qcow_deps["wo_backing"]),
        ],
        [
            "No derivatives",
            len(qcow_deps["wo_derivatives"]),
            size_gb(qcow_deps["wo_derivatives"]),
        ],
        ["Volatile storages", len(volatile), size_gb(volatile)],
    ]

    print(
        tabulate(
            table_data,
            headers="firstrow",
            tablefmt="grid",
            stralign="center",
            numalign="center",
        )
    )

    # Deletable summary
    table_data = [
        ["To delete", "What", "Count", "Size (GB)"],
        [
            "Storages in API not in system",
            "API storage&domains entries",
            len(storages_in_db_not_in_system),
            "-",
        ],
        [
            "Dead artifacts (non-qcow2)",
            "files",
            len(dead_artifacts),
            size_gb(dead_artifacts),
        ],
        [
            "Duplicate uploads",
            "qcow files",
            len(duplicate_uploads),
            size_gb(duplicate_uploads),
        ],
        [
            "Other non-qcow2 (media, etc.)",
            "files",
            len(unknown_non_qcow),
            size_gb(unknown_non_qcow),
        ],
        [
            "Volatile storages",
            "qcow files",
            len(volatile),
            size_gb(volatile),
        ],
        [
            "Broken chain",
            "qcow files",
            len(broken_chain),
            size_gb(broken_chain),
        ],
        [
            "Storages in system not in API with no derivatives",
            "qcow files",
            len(deletable),
            size_gb(deletable),
        ],
    ]

    print(
        tabulate(
            table_data,
            headers="firstrow",
            tablefmt="grid",
            stralign="center",
            numalign="center",
        )
    )
    print(
        "Total size of storages that may be deleted: ",
        size_gb(volatile)
        + size_gb(dead_artifacts)
        + size_gb(duplicate_uploads)
        + size_gb(broken_chain)
        + size_gb(deletable),
    )

    # ── DB vs Disk consistency check ──────────────────────────────────────
    log("Checking DB-vs-disk consistency...")

    # Build filesystem lookup: path -> stat
    fs_lookup = {}
    for f in qcow_storages:
        try:
            fs_lookup[f] = Path(f).stat()
        except OSError:
            pass

    # Group API storages by status
    ready_storages = [s for s in raw_storages if s["status"] == "ready"]
    deleted_storages = [s for s in raw_storages if s["status"] == "deleted"]
    other_storages = [
        s for s in raw_storages if s["status"] not in ("ready", "deleted")
    ]

    # Check: ready in DB but file missing on disk
    ready_missing = []
    for s in ready_storages:
        if s["path"] not in fs_lookup:
            ready_missing.append(s)

    # Check: deleted in DB but file still on disk
    deleted_ghost = []
    for s in deleted_storages:
        if s["path"] in fs_lookup:
            deleted_ghost.append(s)

    # Check: ready in DB, file exists, but DB actual-size mismatches disk
    size_mismatches = []
    SIZE_THRESHOLD = 1024 * 1024  # 1MB
    for s in ready_storages:
        if s["path"] not in fs_lookup:
            continue
        db_size = (s.get("qemu-img-info") or {}).get("actual-size", 0) or 0
        real_size = fs_lookup[s["path"]].st_size
        if db_size and abs(real_size - db_size) > SIZE_THRESHOLD:
            size_mismatches.append(
                {
                    "id": s["id"],
                    "path": s["path"],
                    "db_size": db_size,
                    "real_size": real_size,
                    "diff_mb": abs(real_size - db_size) / (1024 * 1024),
                }
            )

    # Check: ready in DB, file exists, but DB parent doesn't match disk backing
    parent_mismatches = []
    broken_set = set(broken_chain)
    for s in ready_storages:
        if s["path"] not in fs_lookup or s["path"] in broken_set:
            continue
        db_parent = s.get("parent")
        disk_backing = qcow_deps.get("dependency_map", {}).get(s["path"])
        if disk_backing:
            disk_parent_uuid = Path(disk_backing).stem
        else:
            disk_parent_uuid = None
        if db_parent != disk_parent_uuid:
            parent_mismatches.append(
                {
                    "id": s["id"],
                    "db_parent": db_parent,
                    "disk_parent": disk_parent_uuid,
                }
            )

    # Print DB consistency report
    print("\n" + "=" * 70)
    print("DB vs DISK CONSISTENCY")
    print("=" * 70)

    all_ok = True

    # Status distribution
    status_table = [["DB Status", "Count", "With domains"]]
    for label, group in [
        ("ready", ready_storages),
        ("deleted", deleted_storages),
    ]:
        with_dom = sum(1 for s in group if s.get("domains", 0) > 0)
        status_table.append([label, len(group), with_dom])
    if other_storages:
        for s in other_storages:
            status_table.append(
                [
                    s["status"],
                    1,
                    1 if s.get("domains", 0) > 0 else 0,
                ]
            )
    print(
        tabulate(
            status_table,
            headers="firstrow",
            tablefmt="grid",
            stralign="center",
            numalign="center",
        )
    )

    # Ready but missing
    if ready_missing:
        all_ok = False
        with_domains = sum(1 for s in ready_missing if s.get("domains", 0) > 0)
        print(f"\nREADY in DB but FILE MISSING: {len(ready_missing)}")
        if with_domains:
            print(f"  WARNING: {with_domains} of these have domains attached!")
        for s in ready_missing:
            dom = s.get("domains", 0)
            dom_str = f"  domains={dom}" if dom else ""
            print(f"  {s['id']}{dom_str}  {s['path']}")

    # Deleted but ghost
    if deleted_ghost:
        all_ok = False
        print(f"\nDELETED in DB but FILE EXISTS: {len(deleted_ghost)}")
        for s in deleted_ghost:
            real_size = fs_lookup[s["path"]].st_size
            print(f"  {s['id']}  {format_size(real_size)}  {s['path']}")

    # Size mismatches
    if size_mismatches:
        all_ok = False
        size_mismatches.sort(key=lambda x: x["diff_mb"], reverse=True)
        print(
            f"\nSIZE MISMATCH (DB vs disk, >{SIZE_THRESHOLD // (1024*1024)}MB): "
            f"{len(size_mismatches)}"
        )
        for m in size_mismatches[:15]:
            print(
                f"  {m['id']}  DB={format_size(m['db_size'])} "
                f" disk={format_size(m['real_size'])} "
                f" diff={m['diff_mb']:.0f}MB"
            )
        if len(size_mismatches) > 15:
            print(f"  ... and {len(size_mismatches) - 15} more")

    # Parent mismatches
    if parent_mismatches:
        all_ok = False
        print(f"\nPARENT MISMATCH (DB vs disk backing): {len(parent_mismatches)}")
        for m in parent_mismatches[:10]:
            print(f"  {m['id']}")
            print(f"    DB parent:   {m['db_parent']}")
            print(f"    Disk parent: {m['disk_parent']}")
        if len(parent_mismatches) > 10:
            print(f"  ... and {len(parent_mismatches) - 10} more")

    if all_ok:
        print("\nAll DB records consistent with filesystem.")

    print("=" * 70)

    # ── Templates without dependents ─────────────────────────────────────
    unused_templates = _find_templates_without_dependents(raw_storages)
    if unused_templates:
        total_unused_size = sum(t["size"] for t in unused_templates)
        print(f"\n{'=' * 70}")
        print("TEMPLATES WITHOUT DEPENDENTS")
        print(f"{'=' * 70}")
        print(
            f"  {len(unused_templates)} templates ({format_size(total_unused_size)})"
            " — no desktop or template depends on them"
        )
        print()
        for ot in unused_templates:
            kids_str = (
                f"  ({ot['deleted_children']} deleted children)"
                if ot["deleted_children"]
