def _build_uuid_to_path_index(qcow_files):
    """Build UUID -> filesystem path index from scanned files."""
    index = {}
    for f in qcow_files:
        uid = Path(f).stem
        if uid not in index:
            index[uid] = f
    return index


def _launch_and_track_tasks(task_map, label="tasks"):
    """Poll tasks until all complete. task_map = {storage_id: task_id}.

    Returns dict: {storage_id: final_task_status}.
    """
    completed = {}
    start = time()
    timeout = 600

    while time() - start < timeout:
        pending = 0
        for sid, tid in task_map.items():
            if tid in completed:
                continue
            try:
                task = poll_task(tid)
                if task.get("status") in ("finished", "failed", "canceled"):
                    completed[tid] = task.get("status")
                else:
                    pending += 1
            except Exception:
                pending += 1

        elapsed = int(time() - start)
        done = len(completed)
        total = len(task_map)
        if done >= total:
            log(f"  {label}: {done}/{total} done ({elapsed}s)")
            break
        if elapsed % 10 < 6:
            log(f"  {label}: {done}/{total} done, {pending} pending ({elapsed}s)")
        import time as time_mod

        time_mod.sleep(3)

    results = {}
    for sid, tid in task_map.items():
        results[sid] = completed.get(tid, "timeout")
    return results


def cmd_verify(args):
    """Check DB-vs-disk consistency and optionally fix via API."""
    t = time()
    log("Starting DB-vs-disk verification...")

    # ── Fetch data ────────────────────────────────────────────────────────
    log("Getting storages from API...")
    raw_storages = fetch_storages()
    if raw_storages is None:
        log("ERROR: API call failed.")
        sys.exit(1)
    log(f"  {len(raw_storages)} storages in API")

    log("Scanning filesystem...")
    sys_storages = scan_isard_dirs()
    qcow_storages = [s for s in sys_storages if s.endswith(".qcow2")]
    log(f"  {len(qcow_storages)} qcow2 files on disk")

    # Build lookups
    fs_lookup = {}
    for f in qcow_storages:
        try:
            fs_lookup[f] = Path(f).stat()
        except OSError:
            pass

    uuid_to_disk_path = _build_uuid_to_path_index(qcow_storages)

    # ── Detect issues ─────────────────────────────────────────────────────
    ready_missing = []  # ready in DB, file not at DB path
    ready_path_mismatch = []  # ready in DB, file exists elsewhere on disk
    deleted_ghost = []  # deleted in DB, file still on disk

    for s in raw_storages:
        path = s["path"]
        sid = s["id"]
        status = s["status"]

        if status == "ready":
            if path not in fs_lookup:
                # File not at expected path — check if it's elsewhere
                actual = uuid_to_disk_path.get(sid)
                if actual:
                    ready_path_mismatch.append(
                        {
                            "id": sid,
                            "db_path": path,
                            "actual_path": actual,
                            "domains": s.get("domains", 0),
                        }
                    )
                else:
                    ready_missing.append(s)

        elif status == "deleted":
            if path in fs_lookup:
                deleted_ghost.append(s)

    # ── Report ────────────────────────────────────────────────────────────
    print()
    print("=" * 70)
    print("DB vs DISK VERIFICATION")
    print("=" * 70)

    all_ok = True

    if ready_missing:
        all_ok = False
        print(f"\nREADY in DB, file GONE: {len(ready_missing)}")
        for s in ready_missing:
            dom = s.get("domains", 0)
            dom_str = f"  domains={dom}" if dom else ""
            print(f"  {s['id']}{dom_str}")
        if args.fix:
            print(f"  -> Triggering find tasks to mark as deleted...")

    if ready_path_mismatch:
        all_ok = False
        print(f"\nREADY in DB, file at WRONG PATH: {len(ready_path_mismatch)}")
        for m in ready_path_mismatch:
            print(f"  {m['id']}  domains={m['domains']}")
            print(f"    DB:   {m['db_path']}")
            print(f"    Disk: {m['actual_path']}")
        if args.fix:
            print(f"  -> Updating DB paths to match disk...")

    if deleted_ghost:
        all_ok = False
        print(f"\nDELETED in DB, file ON DISK: {len(deleted_ghost)}")
        for s in deleted_ghost:
            size = fs_lookup[s["path"]].st_size
            print(f"  {s['id']}  {format_size(size)}  {s['path']}")
        if args.fix:
            print(f"  -> Triggering find tasks to re-evaluate...")

    if all_ok:
        print("\nAll DB records consistent with filesystem.")
        print("=" * 70)
        log(f"Total execution time: {time()-t:.2f} seconds")
        return

    print("=" * 70)

    # ── Fix mode ──────────────────────────────────────────────────────────
    if not args.fix:
        print("\nRun with --fix to correct these issues.")
        log(f"Total execution time: {time()-t:.2f} seconds")
        return

    print()
    task_map = {}
    actions = {}

    # Fix path mismatches: update DB path via API
    for m in ready_path_mismatch:
        sid = m["id"]
        try:
            task_id = update_storage_path(sid, m["actual_path"])
            task_map[sid] = task_id
            actions[sid] = f"path_update: {m['db_path']} -> {m['actual_path']}"
            log(f"  Updated path for {sid}")
        except Exception as e:
            log(f"  FAILED to update path for {sid}: {e}")

    # Fix ready-missing: trigger find to mark as deleted
    for s in ready_missing:
        sid = s["id"]
        try:
            task_id = trigger_find(sid)
            task_map[sid] = task_id
            actions[sid] = "find: ready but file missing"
        except Exception as e:
            log(f"  FAILED to trigger find for {sid}: {e}")

    # Fix deleted-ghost: trigger find to re-evaluate
    for s in deleted_ghost:
        sid = s["id"]
        try:
            task_id = trigger_find(sid)
            task_map[sid] = task_id
            actions[sid] = "find: deleted but file on disk"
        except Exception as e:
            log(f"  FAILED to trigger find for {sid}: {e}")

    if not task_map:
        log("No tasks to run.")
        log(f"Total execution time: {time()-t:.2f} seconds")
        return

    log(f"Launched {len(task_map)} tasks, waiting for completion...")
    results = _launch_and_track_tasks(task_map, label="verify")

    # Report results
    finished = sum(1 for s in results.values() if s == "finished")
    failed = sum(1 for s in results.values() if s == "failed")

    print()
    print(f"Results: {finished} finished, {failed} failed")
    for sid, status in results.items():
        if status != "finished":
            log(f"  {sid}: {status} ({actions.get(sid, '')})")

    log(f"Total execution time: {time()-t:.2f} seconds")


