def cmd_recover(args):
    """Recover failed desktops by recreating missing incremental disks."""
    t = time()
    log("Starting recovery scan...")

    log("Fetching storages from API...")
    raw_storages = fetch_storages()
    if raw_storages is None:
        log("ERROR: API call failed.")
        sys.exit(1)

    by_id = {s["id"]: s for s in raw_storages}

    # Find recoverable: deleted storage + healthy parent on disk + has domains
    recoverable = []
    for s in raw_storages:
        if s["status"] != "deleted":
            continue
        parent_id = s.get("parent")
        if not parent_id:
            continue
        parent = by_id.get(parent_id)
        if not parent or parent["status"] != "ready":
            continue
        parent_path = parent["path"]
        if not Path(parent_path).exists():
            continue
        storage_path = s["path"]
        if Path(storage_path).exists():
            continue  # file exists, not missing
        if s.get("domains", 0) == 0:
            continue  # no domains, nothing to recover

        recoverable.append(
            {
                "id": s["id"],
                "path": storage_path,
                "parent_id": parent_id,
                "parent_path": parent_path,
                "domains": s.get("domains", 0),
                "user_id": s.get("user_id", "?"),
            }
        )

    # Report
    print()
    print("=" * 70)
    print("RECOVERABLE DESKTOPS")
    print("=" * 70)
    print(
        f"  Deleted storage + healthy parent + missing file + has domains:"
        f" {len(recoverable)}"
    )

    if not recoverable:
        print("\n  No recoverable desktops found.")
        print("=" * 70)
        log(f"Total execution time: {time()-t:.2f} seconds")
        return

    for r in recoverable:
        print(f"\n  {r['id']}")
        print(f"    path:    {r['path']}")
        print(f"    parent:  {r['parent_path']}")
        print(f"    domains: {r['domains']}  user: {r['user_id']}")

    print("=" * 70)

    if not args.fix:
        print("\nRun with --fix to recreate disks and trigger find tasks.")
        log(f"Total execution time: {time()-t:.2f} seconds")
        return

    # Fix: create incremental disks + trigger find
    print(f"\nRecovering {len(recoverable)} desktops...")
    task_map = {}

    for r in recoverable:
        log(f"  Creating incremental: {r['path']}")
        log(f"    backing: {r['parent_path']}")
        ok, err = create_incremental(r["path"], r["parent_path"])
        if not ok:
            log(f"    FAILED to create: {err}")
            continue

        # Verify the new file
        if not Path(r["path"]).exists():
            log(f"    FAILED: file not created")
            continue

        chain = get_backing_chain(r["path"])
        if chain is None:
            log(f"    WARNING: created but chain is broken")

        log(f"    OK — triggering find task...")
        try:
            task_id = trigger_find(r["id"])
            task_map[r["id"]] = task_id
        except Exception as e:
            log(f"    FAILED to trigger find: {e}")

    if task_map:
        log(f"Waiting for {len(task_map)} find tasks...")
        results = _launch_and_track_tasks(task_map, label="recover")

        finished = sum(1 for s in results.values() if s == "finished")
        failed = sum(1 for s in results.values() if s != "finished")
        print(f"\nRecovered: {finished}, Failed: {failed}")

        if finished:
            print("Desktops should now be in 'Stopped' status" " and ready to start.")

    log(f"Total execution time: {time()-t:.2f} seconds")


