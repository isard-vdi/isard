def cmd_cleanup(args):
    """Generate categorized file lists for storage cleanup."""
    t = time()
    log("Starting cleanup analysis...")

    log("Getting storages from API...")
    raw_storages = fetch_storages()
    if raw_storages is None:
        log("ERROR: API call failed. Cannot determine which files are tracked.")
        log("ABORTING: refusing to write a cleanup report without API verification.")
        sys.exit(1)
    bad_db_records = list(fetch_storages.last_bad_records)

    db_storages = [s["path"] for s in raw_storages]
    # Build lookup by path for status/domain checks
    db_storage_lookup = {}
    for s in raw_storages:
        db_storage_lookup[s["path"]] = {
            "id": s["id"],
            "status": s.get("status", "unknown"),
            "has_domains": s.get("domains", 0) > 0,
        }
    log(f" - Got {len(db_storages)} storages from API in {time()-t:.2f} seconds")

    log("Getting storages from system...")
    sys_storages = scan_isard_dirs()
    log(f" - Got {len(sys_storages)} storages from system in {time()-t:.2f} seconds")

    log("Getting medias from API...")
    medias = fetch_medias()
    if medias is None:
        log(
            " - WARNING: media API call failed."
            " Continuing without media classification."
        )
        bad_media_records = []
        info_medias_never_downloaded = []
    else:
        bad_media_records = list(fetch_medias.last_bad_records)
        info_medias_never_downloaded = list(
            getattr(fetch_medias, "last_info_never_downloaded", [])
        )
