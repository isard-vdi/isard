def cmd_full_cleanup(args):
    """Full pipeline: verify, repair chains, classify, and move unusable files."""
    t = time()
    dry_run = bool(getattr(args, "dry_run", False))
    log("=" * 60)
    if dry_run:
        log("FULL STORAGE MAINTENANCE  (DRY RUN — no changes will be made)")
    else:
        log("FULL STORAGE MAINTENANCE")
    log("=" * 60)
    actions_planned = []

    # ── Step 1: Fetch API data ────────────────────────────────────────────
    log("\n[1/6] Fetching storage records from API...")
    raw_storages = fetch_storages()
    if raw_storages is None:
        log("ERROR: API call failed. Cannot proceed without API verification.")
        sys.exit(1)

    db_storages = [s["path"] for s in raw_storages]
    db_storage_lookup = {}
    for s in raw_storages:
        db_storage_lookup[s["path"]] = {
            "id": s["id"],
            "status": s.get("status", "unknown"),
            "has_domains": s.get("domains", 0) > 0,
        }
    log(f"  {len(db_storages)} storages in API")

    medias = fetch_medias()
    if medias is None:
        log("  WARNING: media API call failed; orphan media will not be moved.")
    else:
        log(f"  {len(medias)} medias in API")

    # ── Step 2: Scan filesystem ───────────────────────────────────────────
    log("\n[2/6] Scanning filesystem...")
    sys_storages = scan_isard_dirs()
    qcow_storages = [s for s in sys_storages if s.endswith(".qcow2")]
    media_storages = [s for s in sys_storages if s.endswith((".iso", ".fd"))]
    non_qcow_storages = [
        s for s in sys_storages if not s.endswith((".qcow2", ".iso", ".fd"))
    ]
    storages_in_system_not_in_db = set(qcow_storages) - set(db_storages)
    log(
        f"  {len(qcow_storages)} qcow2 files,"
        f" {len(media_storages)} media files,"
        f" {len(non_qcow_storages)} other files"
    )
    log(f"  {len(storages_in_system_not_in_db)} qcow2 files not in API")

    # Sanity check
    if len(qcow_storages) > 0:
        orphan_ratio = len(storages_in_system_not_in_db) / len(qcow_storages)
        if orphan_ratio > 0.8 and len(storages_in_system_not_in_db) > 50:
            log(
                f"ERROR: {orphan_ratio:.0%} orphan ratio is suspiciously high."
                " Possible API data issue. Aborting."
            )
            sys.exit(1)

    # ── Step 3: Check integrity + dependencies in one pass ────────────────
    log("\n[3/6] Checking backing chain integrity + dependencies...")
    if getattr(args, "rescan", False):
        log("  --rescan set: ignoring qcow cache, re-running qemu-img on all files.")
        cache_in = {}
    else:
        cache_in = load_qcow_cache()
    broken_chain, qcow_deps, fresh_cache = analyze_integrity_and_dependencies(
        qcow_storages, cache=cache_in
    )
    log(f"  {len(broken_chain)} files with broken chains")

    repaired_files = []
    if broken_chain:
        log(
            "\n[4/6] Diagnosing broken chains (searching for relocated backing files)..."
        )
        diag_results = diagnose_broken_chains(broken_chain)

        recoverable = [r for r in diag_results if r["found_at"] and r["rebase_cmd"]]
        corrupt = [r for r in diag_results if r["corrupt"]]
        truly_missing = [
            r
            for r in diag_results
            if not r["found_at"] and not r["corrupt"] and r["missing_uuid"]
        ]

        print()
        print(f"  Broken chain diagnosis:")
        print(f"    Recoverable:    {len(recoverable)}")
        print(f"    Truly missing:  {len(truly_missing)}")
        print(f"    Corrupt:        {len(corrupt)}")

        # Attempt repairs on recoverable files
        if recoverable:
            to_fix = recoverable
            if not args.include_templates:
                template_count = sum(
                    1 for r in recoverable if "/isard/templates" in r["broken_link"]
                )
                to_fix = [
                    r for r in recoverable if "/isard/templates" not in r["broken_link"]
                ]
                if template_count:
                    log(
                        f"  Skipping {template_count} template repairs"
                        " (use --include-templates)"
                    )

            if to_fix:
                if dry_run:
                    log(
                        f"  DRY RUN: would attempt to repair {len(to_fix)}"
                        " broken chains via qemu-img rebase"
                    )
                    for r in to_fix:
                        actions_planned.append(
                            {
                                "action": "rebase",
                                "file": r["file"],
                                "broken_link": r["broken_link"],
                                "found_at": r["found_at"],
                                "rebase_cmd": r["rebase_cmd"],
                            }
                        )
                else:
                    log(f"  Repairing {len(to_fix)} broken chains...")
                    for r in to_fix:
                        ok, err = rebase_file(r["broken_link"], r["found_at"])
                        if ok:
                            repaired_files.append(r["file"])
                            log(f"    FIXED: {r['broken_link']}")
                        else:
                            log(f"    FAILED: {r['broken_link']} -> {err}")

        # Repaired files have new mtimes — invalidate their cache entries
        # so the re-analysis sees them as cache misses and re-runs qemu-img
        # only for that subset. Untouched files stay cached.
        if repaired_files:
            log(f"\n  Re-checking integrity after {len(repaired_files)} repairs...")
            for f in repaired_files:
                fresh_cache.pop(f, None)
            broken_chain, qcow_deps, fresh_cache = analyze_integrity_and_dependencies(
                qcow_storages, cache=fresh_cache
            )
            still_broken = set(repaired_files) & set(broken_chain)
            newly_ok = len(repaired_files) - len(still_broken)
            log(
                f"    {newly_ok} chains fully restored, {len(still_broken)} still broken"
            )
            log(f"  Updated broken chain count: {len(broken_chain)}")
    else:
        log("\n[4/6] No broken chains — skipping repair step")

    save_qcow_cache(fresh_cache)

    # ── Step 5: Final classification using deps from step 3 ───────────────
    log("\n[5/6] Classifying files...")

    # Compute final deletable sets
    deletable_orphans = set(qcow_deps["wo_derivatives"]) & storages_in_system_not_in_db
    volatile = get_volatile_storages()

    # Broken chain files that are NOT in DB and have no derivatives
    # are now also safe to move (they're unrecoverable AND no one depends on them)
    broken_not_in_db = set(broken_chain) & storages_in_system_not_in_db
    broken_no_deps = broken_not_in_db - set(qcow_deps.get("reverse_map", {}).keys())

    # Broken chain files that ARE in DB but already marked "deleted"
    # and have no healthy derivatives — the system already gave up on them,
    # they're unrecoverable, keeping the physical file is pointless.
    broken_deleted_in_db = set()
    for f in broken_chain:
        if f in storages_in_system_not_in_db:
            continue  # already in broken_no_deps above
        info = db_storage_lookup.get(f)
        if info and info["status"] == "deleted":
            # Verify no healthy file depends on this as backing
            if f not in qcow_deps.get("reverse_map", {}):
                broken_deleted_in_db.add(f)

    # Classify non-qcow2 files (renamed artifacts, stale copies, etc.)
    dead_artifacts, unknown_non_qcow = _classify_non_qcow2_files(
        non_qcow_storages, qcow_deps, db_storage_lookup=db_storage_lookup
    )

    # Classify .iso/.fd media files against the API media table.
    # Without media API data the orphan bucket stays empty (defensive).
    if medias is not None:
        media_classes = _classify_media_files(media_storages, medias)
    else:
        media_classes = {
            "registered": [],
            "unverified": list(media_storages),
            "orphan": [],
            "db_not_in_system": [],
        }

    # Find duplicate qcow2 files where DB-referenced copy exists at a different path
    duplicate_uploads = _find_duplicate_uploads(qcow_storages, db_storage_lookup)

    log(f"  Deletable orphans (not in DB, no derivatives): {len(deletable_orphans)}")
    log(
        f"  Unrecoverable broken chains (not in DB, no derivatives): {len(broken_no_deps)}"
    )
    log(
        f"  Dead broken chains (deleted in DB, unrecoverable): {len(broken_deleted_in_db)}"
    )
    log(f"  Dead artifacts (non-qcow2, not in any chain): {len(dead_artifacts)}")
    log(
        f"  Orphan medias (ISO/FD not registered in API): {len(media_classes['orphan'])}"
    )
    log(f"  Duplicate uploads (DB copy exists at root): {len(duplicate_uploads)}")
    log(f"  Volatile files: {len(volatile)}")

    # ── Step 5b (optional): Sparsify / Compress healthy files ─────────────
    sparsified_count = 0
    compressed_count = 0
    total_saved = 0

    if args.sparsify or args.compress:
        # Files to optimize: in DB, not broken, qcow2
        all_unusable = (
            deletable_orphans
            | broken_no_deps
            | broken_deleted_in_db
            | set(broken_chain)
            | set(volatile)
        )
        healthy_qcow = [f for f in qcow_storages if f not in all_unusable]
        if not args.include_templates:
            healthy_qcow = [f for f in healthy_qcow if "/isard/templates" not in f]

        if dry_run:
            ops = []
            if args.sparsify:
                ops.append("sparsify")
            if args.compress:
                ops.append("compress")
            log(
