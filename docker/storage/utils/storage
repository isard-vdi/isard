def cmd_repair_chains(args):
    """Diagnose and optionally fix broken backing chains."""
    t = time()
    log("Starting broken chain diagnosis...")

    log("Scanning filesystem for qcow2 files...")
    sys_storages = scan_isard_dirs()
    qcow_storages = [s for s in sys_storages if s.endswith(".qcow2")]
    log(f"  Found {len(qcow_storages)} qcow2 files")

    log("Checking backing chain integrity...")
    broken = analyze_integrity(qcow_storages)
    log(f"  Found {len(broken)} files with broken chains")

    if not broken:
        log("No broken chains found.")
        return

    log("Diagnosing broken chains (searching for relocated backing files)...")
    results = diagnose_broken_chains(broken)

    # Categorize results
    recoverable = [r for r in results if r["found_at"] and r["rebase_cmd"]]
    corrupt = [r for r in results if r["corrupt"]]
    truly_missing = [
        r for r in results
        if not r["found_at"] and not r["corrupt"] and r["missing_uuid"]
    ]
    no_backing = [
        r for r in results
        if not r["corrupt"] and not r["missing_uuid"]
    ]

    # Print report
    print()
    print("=" * 80)
    print("BROKEN CHAIN DIAGNOSIS")
    print("=" * 80)
    print(f"  Total broken:     {len(broken)}")
    print(f"  Recoverable:      {len(recoverable)}  (backing UUID found at different path)")
    print(f"  Truly missing:    {len(truly_missing)}  (backing UUID not found anywhere)")
    print(f"  Corrupt:          {len(corrupt)}  (qemu-img cannot read file)")
    if no_backing:
        print(f"  No backing ref:   {len(no_backing)}  (root image or other issue)")
    print("=" * 80)

    if recoverable:
        print(f"\nRecoverable files ({len(recoverable)}):")
        for r in recoverable:
            print(f"\n  File:        {r['file']}")
            if r["broken_link"] != r["file"]:
                print(f"  Broken at:   {r['broken_link']}")
            print(f"  Expected:    {r['missing_path']}")
            print(f"  Found at:    {r['found_at']}")
            print(f"  Fix:         {r['rebase_cmd']}")

    if truly_missing:
        print(f"\nTruly missing backing files ({len(truly_missing)}):")
        for r in truly_missing:
            print(f"  {r['file']}")
            print(f"    missing: {r['missing_path']} (UUID {r['missing_uuid']} not on disk)")

    if corrupt:
        print(f"\nCorrupt files ({len(corrupt)}):")
        for r in corrupt:
            print(f"  {r['file']}  (qemu-img info fails)")

    # Fix mode
    if args.fix and recoverable:
        # Filter out templates unless explicitly included
        to_fix = recoverable
        if not args.include_templates:
            templates_skipped = [
                r for r in recoverable if "/isard/templates" in r["broken_link"]
            ]
            to_fix = [
                r for r in recoverable if "/isard/templates" not in r["broken_link"]
            ]
            if templates_skipped:
                log(
                    f"Skipping {len(templates_skipped)} template files."
                    " Use --include-templates to fix them."
                )

        if not to_fix:
            log("No non-template recoverable files to fix.")
        else:
            print(f"\nApplying {len(to_fix)} fixes...")

        fixed = 0
        failed = 0
        for r in to_fix:
            log(f"  Rebasing {r['broken_link']}...")
            ok, err = rebase_file(r["broken_link"], r["found_at"])
            if ok:
                fixed += 1
                log(f"    OK")
            else:
                failed += 1
                log(f"    FAILED: {err}")

        print(f"\nFixed: {fixed}, Failed: {failed}")

        if fixed:
            # Verify fixes
            log("Verifying fixes...")
            still_broken = analyze_integrity(
                [r["file"] for r in recoverable]
            )
            if still_broken:
                log(
                    f"  WARNING: {len(still_broken)} files still have broken"
                    " chains after fix (chain may be broken further up)"
                )
                for f in still_broken:
                    print(f"    Still broken: {f}")
            else:
                log(f"  All {fixed} files verified — chains intact")

    elif args.fix and not recoverable:
        log("No recoverable files to fix.")

    log(f"Total execution time: {time()-t:.2f} seconds")


# ─── full subcommand ─────────────────────────────────────────────────────────


def cmd_full_cleanup(args):
    """Full pipeline: verify, repair chains, classify, and move unusable files."""
    t = time()
    log("=" * 60)
    log("FULL STORAGE MAINTENANCE")
    log("=" * 60)

    # ── Step 1: Fetch API data ────────────────────────────────────────────
    log("\n[1/6] Fetching storage records from API...")
    raw_storages = fetch_storages()
    if raw_storages is None:
        log("ERROR: API call failed. Cannot proceed without API verification.")
        sys.exit(1)

    db_storages = [s["path"] for s in raw_storages]
    db_storage_lookup = {}
    for s in raw_storages:
        db_storage_lookup[s["path"]] = {
            "id": s["id"],
            "status": s.get("status", "unknown"),
            "has_domains": s.get("domains", 0) > 0,
        }
    log(f"  {len(db_storages)} storages in API")

    # ── Step 2: Scan filesystem ───────────────────────────────────────────
    log("\n[2/6] Scanning filesystem...")
    sys_storages = scan_isard_dirs()
    qcow_storages = [s for s in sys_storages if s.endswith(".qcow2")]
    non_qcow_storages = [s for s in sys_storages if not s.endswith(".qcow2")]
    storages_in_system_not_in_db = set(qcow_storages) - set(db_storages)
    log(f"  {len(qcow_storages)} qcow2 files, {len(non_qcow_storages)} other files")
    log(f"  {len(storages_in_system_not_in_db)} qcow2 files not in API")

    # Sanity check
    if len(qcow_storages) > 0:
        orphan_ratio = len(storages_in_system_not_in_db) / len(qcow_storages)
        if orphan_ratio > 0.8 and len(storages_in_system_not_in_db) > 50:
            log(
                f"ERROR: {orphan_ratio:.0%} orphan ratio is suspiciously high."
                " Possible API data issue. Aborting."
            )
            sys.exit(1)

    # ── Step 3: Check integrity + diagnose broken chains ──────────────────
    log("\n[3/6] Checking backing chain integrity...")
    broken_chain = analyze_integrity(qcow_storages)
    log(f"  {len(broken_chain)} files with broken chains")

    repaired_files = []
    if broken_chain:
        log("\n[4/6] Diagnosing broken chains (searching for relocated backing files)...")
        diag_results = diagnose_broken_chains(broken_chain)

        recoverable = [r for r in diag_results if r["found_at"] and r["rebase_cmd"]]
        corrupt = [r for r in diag_results if r["corrupt"]]
        truly_missing = [
            r for r in diag_results
            if not r["found_at"] and not r["corrupt"] and r["missing_uuid"]
        ]

        print()
        print(f"  Broken chain diagnosis:")
        print(f"    Recoverable:    {len(recoverable)}")
        print(f"    Truly missing:  {len(truly_missing)}")
        print(f"    Corrupt:        {len(corrupt)}")

        # Attempt repairs on recoverable files
        if recoverable:
            to_fix = recoverable
            if not args.include_templates:
                template_count = sum(
                    1 for r in recoverable
                    if "/isard/templates" in r["broken_link"]
                )
                to_fix = [
                    r for r in recoverable
                    if "/isard/templates" not in r["broken_link"]
                ]
                if template_count:
                    log(
                        f"  Skipping {template_count} template repairs"
                        " (use --include-templates)"
                    )

            if to_fix:
                log(f"  Repairing {len(to_fix)} broken chains...")
                for r in to_fix:
                    ok, err = rebase_file(r["broken_link"], r["found_at"])
                    if ok:
                        repaired_files.append(r["file"])
                        log(f"    FIXED: {r['broken_link']}")
                    else:
                        log(f"    FAILED: {r['broken_link']} -> {err}")

        # Re-check integrity after repairs
        if repaired_files:
            log(f"\n  Re-checking integrity after {len(repaired_files)} repairs...")
            still_broken = analyze_integrity(
                [r for r in repaired_files]
            )
            newly_ok = len(repaired_files) - len(still_broken)
            log(f"    {newly_ok} chains fully restored, {len(still_broken)} still broken")

            # Update the broken chain list
            broken_chain = analyze_integrity(qcow_storages)
            log(f"  Updated broken chain count: {len(broken_chain)}")
    else:
        log("\n[4/6] No broken chains — skipping repair step")

    # ── Step 5: Analyze dependencies with updated state ───────────────────
    log("\n[5/6] Analyzing dependencies...")
    qcow_deps = analyze_dependencies(qcow_storages)

    # Compute final deletable sets
    deletable_orphans = set(qcow_deps["wo_derivatives"]) & storages_in_system_not_in_db
    volatile = get_volatile_storages()

    # Broken chain files that are NOT in DB and have no derivatives
    # are now also safe to move (they're unrecoverable AND no one depends on them)
    broken_not_in_db = set(broken_chain) & storages_in_system_not_in_db
    broken_no_deps = broken_not_in_db - set(qcow_deps.get("reverse_map", {}).keys())

    # Broken chain files that ARE in DB but already marked "deleted"
    # and have no healthy derivatives — the system already gave up on them,
    # they're unrecoverable, keeping the physical file is pointless.
    broken_deleted_in_db = set()
    for f in broken_chain:
        if f in storages_in_system_not_in_db:
            continue  # already in broken_no_deps above
        info = db_storage_lookup.get(f)
        if info and info["status"] == "deleted":
            # Verify no healthy file depends on this as backing
            if f not in qcow_deps.get("reverse_map", {}):
                broken_deleted_in_db.add(f)

    # Classify non-qcow2 files (renamed artifacts, stale copies, etc.)
    dead_artifacts, unknown_non_qcow = _classify_non_qcow2_files(
        non_qcow_storages, qcow_deps
    )

    # Find duplicate qcow2 files where DB-referenced copy exists at a different path
    duplicate_uploads = _find_duplicate_uploads(qcow_storages, db_storage_lookup)

    log(f"  Deletable orphans (not in DB, no derivatives): {len(deletable_orphans)}")
    log(f"  Unrecoverable broken chains (not in DB, no derivatives): {len(broken_no_deps)}")
    log(f"  Dead broken chains (deleted in DB, unrecoverable): {len(broken_deleted_in_db)}")
    log(f"  Dead artifacts (non-qcow2, not in any chain): {len(dead_artifacts)}")
    log(f"  Duplicate uploads (DB copy exists at root): {len(duplicate_uploads)}")
    log(f"  Volatile files: {len(volatile)}")

    # ── Step 5b (optional): Sparsify / Compress healthy files ─────────────
    sparsified_count = 0
    compressed_count = 0
    total_saved = 0

    if args.sparsify or args.compress:
        # Files to optimize: in DB, not broken, qcow2
        all_unusable = deletable_orphans | broken_no_deps | broken_deleted_in_db | set(broken_chain) | set(volatile)
        healthy_qcow = [
            f for f in qcow_storages
            if f not in all_unusable
        ]
        if not args.include_templates:
            healthy_qcow = [f for f in healthy_qcow if "/isard/templates" not in f]

        log(f"\n  Optimizing {len(healthy_qcow)} healthy qcow2 files...")

        for i, f in enumerate(healthy_qcow, 1):
            if args.sparsify:
                ok, saved, err = sparsify_file(f)
                if ok:
                    sparsified_count += 1
                    total_saved += max(saved, 0)
                elif err:
                    log(f"    sparsify skip {Path(f).name}: {err}")

            if args.compress:
                ok, saved, err = compress_file(f)
                if ok:
                    compressed_count += 1
                    total_saved += max(saved, 0)
                elif err:
                    log(f"    compress skip {Path(f).name}: {err}")

            if i % 10 == 0 or i == len(healthy_qcow):
                log(
                    f"    Progress: {i}/{len(healthy_qcow)}"
                    f" | saved so far: {format_size(total_saved)}"
                )

        log(f"  Sparsified: {sparsified_count}, Compressed: {compressed_count}")
        log(f"  Total space reclaimed: {format_size(total_saved)}")

    # ── Step 6: Export reports and move files ──────────────────────────────
    log("\n[6/6] Generating report and moving unusable files...")
    output_dir = get_output_dir()

    # Write file lists
    storages_in_db_not_in_system = set(db_storages) - set(qcow_storages)
    files_info = [
        ("ok_db_not_in_system.txt", storages_in_db_not_in_system),
        ("ok_system_not_in_db.txt", storages_in_system_not_in_db),
        ("ok_no_backing_file.txt", qcow_deps["wo_backing"]),
        ("ok_no_derivatives.txt", qcow_deps["wo_derivatives"]),
        ("bad_broken_chain.txt", broken_chain),
        ("volatile_storage.txt", volatile),
        ("bad_non_qcow2.txt", non_qcow_storages),
        ("bad_deletable_orphans.txt", deletable_orphans),
        ("bad_dead_artifacts.txt", dead_artifacts),
        ("bad_duplicate_uploads.txt", duplicate_uploads),
    ]
    if repaired_files:
        files_info.append(("repaired_chains.txt", repaired_files))

    # Templates without dependents (informational, not moved)
    unused_templates = _find_templates_without_dependents(raw_storages)
    if unused_templates:
        files_info.append((
            "info_templates_without_dependents.txt",
            [t["id"] for t in unused_templates],
        ))
        total_unused_size = sum(t["size"] for t in unused_templates)
        log(
            f"  Templates without dependents:"
            f" {len(unused_templates)} ({format_size(total_unused_size)})"
        )

    for filename, file_list in files_info:
        write_file_list(output_dir, filename, file_list)

    # Collect all movable files — everything unusable goes to to_delete
    all_movable_orphans = deletable_orphans | broken_no_deps | broken_deleted_in_db
    movable = _collect_movable_files(
        all_movable_orphans, volatile, db_storage_lookup, qcow_deps,
        dead_artifacts=dead_artifacts,
        duplicate_uploads=duplicate_uploads,
        include_templates=args.include_templates,
    )
    _move_deletable_files(movable, output_dir)

    # ── Summary ───────────────────────────────────────────────────────────
    print()
    print("=" * 60)
    print("FULL MAINTENANCE SUMMARY")
    print("=" * 60)
    print(f"  API storages:          {len(db_storages)}")
    print(f"  Filesystem qcow2:      {len(qcow_storages)}")
    print(f"  Chains repaired:       {len(repaired_files)}")
    print(f"  Broken (remaining):    {len(broken_chain)}")
    if sparsified_count or compressed_count:
        print(f"  Sparsified:            {sparsified_count}")
        print(f"  Compressed:            {compressed_count}")
        print(f"  Space reclaimed:       {format_size(total_saved)}")
    print(f"  Report exported to:    {output_dir}")
    print("=" * 60)

    log(f"Total execution time: {time()-t:.2f} seconds")


