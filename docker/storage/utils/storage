def _get_file_size_worker(file_path):
    """Worker function to get actual size for a single file."""
    info = get_full_info(file_path)
    if info:
        return file_path, info["actual-size"]
    return file_path, None


def _run_size_comparison(sys_storages, threshold_gb):
    """Run size comparison between DB and filesystem."""
    from tabulate import tabulate

    print("\n" + "=" * 80)
    print("STARTING SIZE COMPARISON ANALYSIS")
    print("=" * 80)

    log("Fetching storage data with qemu-img-info.actual-size from API...")
    size_start = time()
    db_storages_with_size = fetch_storages_with_size()
    log(
        f" - Got {len(db_storages_with_size)} storages from API"
        f" in {time()-size_start:.2f} seconds"
    )

    db_lookup = {s["path"]: s for s in db_storages_with_size}
    qcow_files = [f for f in sys_storages if f.endswith(".qcow2") and f in db_lookup]

    log(f"Getting actual sizes for {len(qcow_files)} qcow2 files...")
    fs_sizes = {}
    total_files = len(qcow_files)
    processed = 0
    start_time = time()

    with ThreadPoolExecutor(max_workers=10) as executor:
        futures = {
            executor.submit(_get_file_size_worker, f): f for f in qcow_files
        }
        for future in as_completed(futures):
            file_path, actual_size = future.result()
            fs_sizes[file_path] = actual_size
            processed += 1
            if processed % 100 == 0 or processed == total_files:
                elapsed = time() - start_time
                if 0 < processed < total_files:
                    avg = elapsed / processed
                    remaining = avg * (total_files - processed)
                    pct = (processed / total_files) * 100
                    log(
                        f"  Progress: {processed}/{total_files} ({pct:.1f}%)"
                        f" - Est. {format_time_remaining(remaining)} remaining"
                    )
                elif processed == total_files:
                    log(f"  Progress: {processed}/{total_files} (100.0%) - Done")

    # Compare
    matched = []
    discrepancies = []
    missing_in_fs = []
    total_db_size = 0
    total_fs_size = 0

    for db_storage in db_storages_with_size:
        path = db_storage["path"]
        db_size = db_storage["db_actual_size"]
        total_db_size += db_size

        if path in fs_sizes:
            fs_size = fs_sizes[path]
            if fs_size is not None:
                total_fs_size += fs_size
                diff_bytes = abs(fs_size - db_size)
                diff_gb = diff_bytes / (1024**3)

                if diff_gb >= threshold_gb:
                    discrepancies.append(
                        {
                            "path": path,
                            "id": db_storage["id"],
                            "db_size_gb": round(db_size / (1024**3), 2),
                            "fs_size_gb": round(fs_size / (1024**3), 2),
                            "diff_gb": round(diff_gb, 2),
                            "diff_pct": round(
                                (diff_bytes / max(db_size, 1)) * 100, 1
                            ),
                        }
                    )
                else:
                    matched.append(path)
            else:
                missing_in_fs.append(path)

    discrepancies.sort(key=lambda x: x["diff_gb"], reverse=True)

    log(f" - Comparison completed in {time()-size_start:.2f} seconds")

    # Print report
    print("\n" + "=" * 80)
    print("STORAGE SIZE COMPARISON REPORT")
    print("=" * 80)

    summary_data = [
        ["Metric", "Value"],
        ["Total DB Size (GB)", round(total_db_size / (1024**3), 2)],
        ["Total FS Size (GB)", round(total_fs_size / (1024**3), 2)],
        [
            "Total Difference (GB)",
            round(abs(total_fs_size - total_db_size) / (1024**3), 2),
        ],
        ["Matched Files", len(matched)],
        [f"Discrepancies (>{threshold_gb} GB)", len(discrepancies)],
        ["Missing in FS", len(missing_in_fs)],
    ]

    print("\nSummary:")
    print(
        tabulate(
            summary_data,
            headers="firstrow",
            tablefmt="grid",
            stralign="left",
            numalign="right",
        )
    )

    if discrepancies:
        print(f"\nTop Discrepancies (showing up to 20):")
        disc_data = [
            ["Path", "DB Size (GB)", "FS Size (GB)", "Diff (GB)", "Diff (%)"]
        ]
        for disc in discrepancies[:20]:
            short_path = disc["path"].replace("/isard/", ".../")
            if len(short_path) > 60:
                short_path = "..." + short_path[-57:]
            disc_data.append(
                [
                    short_path,
                    disc["db_size_gb"],
                    disc["fs_size_gb"],
                    disc["diff_gb"],
                    disc["diff_pct"],
                ]
            )

        print(
            tabulate(
                disc_data,
                headers="firstrow",
                tablefmt="grid",
                stralign="left",
                numalign="right",
            )
        )

        if len(discrepancies) > 20:
            print(f"\n  ... and {len(discrepancies) - 20} more discrepancies")

    if missing_in_fs:
        print(
            f"\nFiles in DB but failed to get size from FS"
            f" ({len(missing_in_fs)}):"
        )
        for path in missing_in_fs[:10]:
            print(f"  - {path}")
        if len(missing_in_fs) > 10:
            print(f"  ... and {len(missing_in_fs) - 10} more")

    print("\n" + "=" * 80)


