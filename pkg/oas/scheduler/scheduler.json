          "422": {
            "description": "Unprocessable Content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/advanced/date/{type}/{action}": {
      "post": {
        "tags": [
          "Jobs"
        ],
        "summary": "Schedule a date-triggered (one-shot) job.",
        "description": "Schedule a one-shot job at an absolute timestamp.",
        "operationId": "post_scheduler_advanced_date",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SchedulerAddAdvancedDateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerAddJobResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/delete_jobs": {
      "delete": {
        "tags": [
          "Jobs"
        ],
        "summary": "Delete multiple scheduled jobs.",
        "description": "Delete multiple scheduled jobs by id.",
        "operationId": "delete_scheduler_jobs_bulk",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SchedulerDeleteJobsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerEmptyResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/startswith/{job_id}": {
      "delete": {
        "tags": [
          "Jobs"
        ],
        "summary": "Delete jobs by id prefix.",
        "description": "Delete every scheduled job whose id starts with the given prefix. Returns the list of removed ids.",
        "operationId": "delete_scheduler_jobs_startswith",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerRemoveJobStartswithResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/delete/recycle_bin/{category}": {
      "delete": {
        "tags": [
          "RecycleBin"
        ],
        "summary": "Delete a category recycle-bin job.",
        "description": "Delete the recycle-bin cleanup job for the given category (removes `${category}.recycle_bin_delete`).",
        "operationId": "delete_scheduler_recycle_bin_category",
        "parameters": [
          {
            "name": "category",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerEmptyResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/recycle_bin/old_entries/{action}": {
      "put": {
        "tags": [
          "RecycleBin"
        ],
        "summary": "Configure recycle-bin old-entries cleanup.",
        "description": "Configure the recycle-bin old-entries cleanup job. `action` must be `delete` (to schedule) or `none` (to remove the scheduled job).",
        "operationId": "put_scheduler_recycle_bin_old_entries",
        "parameters": [
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "enum": [
                "delete",
                "none"
              ],
              "type": "string"
            },
            "description": "Action to apply: `delete` schedules a daily cleanup, `none` unschedules it."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SchedulerAddJobResponse"
                    },
                    {
                      "$ref": "#/components/schemas/SchedulerEmptyResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerError"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/logs_desktops/old_entries/{action}": {
      "put": {
        "tags": [
          "Logs"
        ],
        "summary": "Configure desktop-logs old-entries cleanup.",
        "description": "Configure the desktop-logs old-entries cleanup job. `action` must be `delete` or `none`.",
        "operationId": "put_scheduler_logs_desktops_old_entries",
        "parameters": [
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "enum": [
                "delete",
                "none"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SchedulerAddJobResponse"
                    },
                    {
                      "$ref": "#/components/schemas/SchedulerEmptyResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerError"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/logs_users/old_entries/{action}": {
      "put": {
        "tags": [
          "Logs"
        ],
        "summary": "Configure user-logs old-entries cleanup.",
        "description": "Configure the user-logs old-entries cleanup job. `action` must be `delete` or `none`.",
        "operationId": "put_scheduler_logs_users_old_entries",
        "parameters": [
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "enum": [
                "delete",
                "none"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SchedulerAddJobResponse"
                    },
                    {
                      "$ref": "#/components/schemas/SchedulerEmptyResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerError"
                }
              }
