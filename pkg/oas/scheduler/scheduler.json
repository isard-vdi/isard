  },
  "components": {
    "schemas": {
      "SchedulerJobKwargs": {
        "properties": {},
        "type": "object",
        "additionalProperties": true,
        "title": "SchedulerJobKwargs",
        "description": "Arbitrary keyword arguments forwarded to a scheduled action. The scheduler does not introspect these; the target action defines its own expected keys."
      },
      "SchedulerAddJobRequest": {
        "properties": {
          "kwargs": {
            "$ref": "#/components/schemas/SchedulerJobKwargs"
          }
        },
        "type": "object",
        "title": "SchedulerAddJobRequest",
        "description": "Request body for POST /scheduler/{type}/{kind}/{action}/{hour}/{minute}[/{id}]. The scheduler only reads the `kwargs` field; any other top-level keys are accepted but ignored."
      },
      "SchedulerAddAdvancedIntervalRequest": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "kwargs": {
            "$ref": "#/components/schemas/SchedulerJobKwargs"
          },
          "weeks": {
            "type": "integer",
            "default": 0,
            "title": "Weeks"
          },
          "days": {
            "type": "integer",
            "default": 0,
            "title": "Days"
          },
          "hours": {
            "type": "integer",
            "default": 0,
            "title": "Hours"
          },
          "minutes": {
            "type": "integer",
            "default": 0,
            "title": "Minutes"
          },
          "seconds": {
            "type": "integer",
            "default": 0,
            "title": "Seconds"
          },
          "start_date": {
            "type": "string",
            "title": "Start Date",
            "description": "ISO-8601 datetime string (UTC or offset)."
          },
          "end_date": {
            "type": "string",
            "title": "End Date",
            "description": "ISO-8601 datetime string (UTC or offset)."
          },
          "timezone": {
            "type": "string",
            "title": "Timezone"
          },
          "jitter": {
            "type": "integer",
            "title": "Jitter"
          }
        },
        "type": "object",
        "title": "SchedulerAddAdvancedIntervalRequest",
        "description": "Request body for POST /scheduler/advanced/interval/{type}/{action}. Mirrors APScheduler IntervalTrigger parameters. `id` and `kwargs` are popped out before forwarding to the trigger."
      },
      "SchedulerAddAdvancedDateRequest": {
        "properties": {
          "date": {
            "type": "string",
            "title": "Date",
            "description": "ISO-8601 datetime string (UTC or offset)."
          },
          "id": {
            "type": "string",
            "title": "Id"
          },
          "kwargs": {
            "$ref": "#/components/schemas/SchedulerJobKwargs"
          }
        },
        "type": "object",
        "required": [
          "date"
        ],
        "title": "SchedulerAddAdvancedDateRequest",
        "description": "Request body for POST /scheduler/advanced/date/{type}/{action}. `date` is the absolute timestamp to run the action at."
      },
      "SchedulerDeleteJobsRequest": {
        "properties": {
          "jobs_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "title": "Jobs Ids"
          }
        },
        "type": "object",
        "required": [
          "jobs_ids"
        ],
        "title": "SchedulerDeleteJobsRequest",
        "description": "Request body for DELETE /scheduler/delete_jobs."
      },
      "SchedulerJob": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "kind": {
            "type": "string",
            "title": "Kind"
          },
          "type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Type"
          },
          "action": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Action"
          },
          "date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Date",
            "description": "ISO-8601 string with timezone (scheduler formats as `%Y-%m-%dT%H:%M%z`)."
          },
