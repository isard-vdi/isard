{
  "openapi": "3.1.0",
  "info": {
    "title": "Scheduler API. Used only through internal microservices.",
    "version": "v1.0"
  },
  "paths": {
    "/scheduler/healthcheck": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Scheduler healthcheck.",
        "description": "Liveness probe. Returns an empty body on success.",
        "operationId": "get_scheduler_healthcheck",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/scheduler/actions": {
      "get": {
        "tags": [
          "Actions"
        ],
        "summary": "List available scheduler actions.",
        "description": "List all actions the scheduler can run, grouped by kind.",
        "operationId": "get_scheduler_actions",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerActionList"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/action/{action_id}": {
      "get": {
        "tags": [
          "Actions"
        ],
        "summary": "Get kwargs for a scheduler action.",
        "description": "Return the kwargs schema associated with a specific action.",
        "operationId": "get_scheduler_action",
        "parameters": [
          {
            "name": "action_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerActionKwargs"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/recycle_bin_delete/max_time": {
      "get": {
        "tags": [
          "RecycleBin"
        ],
        "summary": "Get recycle-bin retention limits.",
        "description": "Return the current recycle-bin retention (scoped to caller category unless admin) and the admin-configured max.",
        "operationId": "get_scheduler_recycle_bin_delete_max_time",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerMaxTimeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler": {
      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "List scheduled jobs.",
        "description": "List every scheduled job.",
        "operationId": "get_scheduler_jobs",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerJobList"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/{job_id}": {
      "delete": {
        "tags": [
          "Jobs"
        ],
        "summary": "Delete a single scheduled job.",
        "description": "Remove a scheduled job by id.",
        "operationId": "delete_scheduler_job",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerEmptyResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "Get a scheduled job by id.",
        "description": "Fetch a single scheduled job by id. Returns a list with one item to match the listing shape.",
        "operationId": "get_scheduler_job",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerJobList"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/kind/{kind}": {
      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "List jobs by kind.",
        "description": "List scheduled jobs filtered by kind (e.g. `date`, `interval`, `cron`).",
        "operationId": "get_scheduler_jobs_by_kind",
        "parameters": [
          {
            "name": "kind",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerJobList"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/not_date": {
      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "List recurring jobs.",
        "description": "List every scheduled job whose kind is not `date` (i.e. recurring jobs only).",
        "operationId": "get_scheduler_jobs_not_date",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerJobList"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/{type}/{kind}/{action}/{hour}/{minute}": {
      "post": {
        "tags": [
          "Jobs"
        ],
        "summary": "Schedule a job (auto-generated id).",
        "description": "Schedule a job using the APScheduler `kind` trigger (e.g. `cron`). Use the `/scheduler/{type}/{kind}/{action}/{hour}/{minute}/{id}` variant to supply a custom job id.",
        "operationId": "post_scheduler_add_job",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "kind",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hour",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "minute",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SchedulerAddJobRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerAddJobResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/{type}/{kind}/{action}/{hour}/{minute}/{id}": {
      "post": {
        "tags": [
          "Jobs"
        ],
        "summary": "Schedule a job (explicit id).",
        "description": "Same as `/scheduler/{type}/{kind}/{action}/{hour}/{minute}` but with an explicit job id.",
        "operationId": "post_scheduler_add_job_with_id",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "kind",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hour",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "minute",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SchedulerAddJobRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerAddJobResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/advanced/interval/{type}/{action}": {
      "post": {
        "tags": [
          "Jobs"
        ],
        "summary": "Schedule an interval-triggered job.",
        "description": "Schedule a job using APScheduler IntervalTrigger parameters (weeks/days/hours/...).",
        "operationId": "post_scheduler_advanced_interval",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SchedulerAddAdvancedIntervalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
