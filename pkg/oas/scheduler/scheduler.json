          }
        }
      }
    },
    "/scheduler/queues/old_tasks/{action}": {
      "put": {
        "tags": [
          "Queues"
        ],
        "summary": "Configure queues old-tasks cleanup.",
        "description": "Configure the queues old-tasks cleanup job. `action` must be `delete` or `none`.",
        "operationId": "put_scheduler_queues_old_tasks",
        "parameters": [
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "enum": [
                "delete",
                "none"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SchedulerAddJobResponse"
                    },
                    {
                      "$ref": "#/components/schemas/SchedulerEmptyResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
