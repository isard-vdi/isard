    "@types/node": "^20.14.5",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.19",
    "axe-playwright": "^2.0.1",
    "eslint": "^8.57.0",
