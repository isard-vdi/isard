    "jwt-decode": "^4.0.0",
    "lucide-vue-next": "^0.553.0",
    "pinia": "^2.1.7",
    "radix-vue": "^1.9.1",
    "reka-ui": "^2.7.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "universal-cookie": "^7.2.0",
    "vite-svg-loader": "^5.1.0",
    "vue": "^3.4.29",
    "vue-cal": "^4.10.2",
    "vue-i18n": "9",
    "vue-router": "^4.3.3",
    "zod": "^4.3.5"
