    depends_on:
      isard-api:
        condition: service_healthy
        required: true
    environment:
      API_DOMAIN: ""
      API_HYPERVISORS_SECRET: Z8RXkTq2tTA+nT55mwUpLraY6D2RxdICIS/LOvqsqh0=
      API_ISARDVDI_SECRET: tCvVKufwiVyqmSvSHCkB7x/FNCsSxthuVKmBxZy5ElI=
      AUTHENTICATION_AUTHENTICATION_IMPERSONATE_EXPIRATION_TIME: 30m
      AUTHENTICATION_AUTHENTICATION_LIMITS_ENABLED: "true"
      AUTHENTICATION_AUTHENTICATION_LIMITS_INCREMENT_FACTOR: "2"
      AUTHENTICATION_AUTHENTICATION_LIMITS_MAX_ATTEMPTS: "10"
      AUTHENTICATION_AUTHENTICATION_LIMITS_MAX_TIME: 15m
      AUTHENTICATION_AUTHENTICATION_LIMITS_RETRY_AFTER: 1m
      BASTION_ENABLED: "true"
      BUILD_ROOT_PATH: .
      DIRECTVIEWER_MODE: browser
      DOCKER_IMAGE_PREFIX: registry.gitlab.com/isard/isardvdi/
      DOCKER_IMAGE_TAG: main
      DOMAIN: solaris.isardvdi.cat
      FLAVOUR: all-in-one
      FRONTEND_DOCS_URI: https://isard.gitlab.io/isardvdi-docs/
      FRONTEND_VIEWERS_DOCS_URI: https://isard.gitlab.io/isardvdi-docs/user/viewers/viewers/
      GOLANG_BUILD_IMAGE: golang:1.24.3-alpine3.22
      GOLANG_RUN_IMAGE: alpine:3.22.0

      HAPROXY_LOGGING: .
      HAPROXY_RUN_IMAGE: haproxy:3.3-alpine3.22
      LOG_LEVEL: INFO
      SESSIONS_SESSIONS_EXPIRATION_TIME: 5m
      SESSIONS_SESSIONS_MAX_RENEW_TIME: 30m
      SESSIONS_SESSIONS_MAX_TIME: 8h
      SRC_VERSION_ID: main-dirty
      SRC_VERSION_LINK: ""
      WEBAPP_ADMIN_PWD: Pirinives5
      WG_GUESTS_DHCP_MASK: "23"
      WG_GUESTS_NETS: 10.2.0.0/16
      WG_GUESTS_RESERVED_HOSTS: "20"
      WG_HYPERS_NET: 10.1.0.0/24
      WG_HYPERS_PORT: "4443"
      WG_MAIN_NET: 10.0.0.0/14
      WG_USERS_NET: 10.0.0.0/16
      WG_USERS_PORT: "443"
    image: registry.gitlab.com/isard/isardvdi/vpn:main
    logging:
      driver: json-file
      options:
        max-file: "5"
        max-size: 10m
        tag: '{{.ImageName}}|{{.Name}}|{{.ImageFullID}}|{{.FullID}}'
    networks:
      isard-network:
        ipv4_address: 172.31.255.23
    ports:
      - mode: ingress
        target: 443
        published: "443"
        protocol: udp
      - mode: ingress
        target: 4443
        published: "4443"
        protocol: udp
    privileged: true
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    volumes:
      - type: bind
        source: /sys
        target: /sys
        bind: {create_host_path: true}
      - type: bind
        source: /opt/isard/wireguard/certs
        target: /certs
        bind: {create_host_path: true}
      - type: bind
        source: /opt/isard/certs/default
        target: /portal-certs
        read_only: true
        bind: {create_host_path: true}
      - type: bind
        source: /opt/isard/dnsmasq
        target: /var/lib/misc
        bind: {create_host_path: true}
      - type: bind
        source: /opt/isard/dnsmasq/static_leases
        target: /var/lib/static_leases
        bind: {create_host_path: true}
      - type: bind
        source: /opt/isard-local/conntrack
        target: /conntrack
        bind: {create_host_path: true}
      - type: bind
        source: /proc/sys/net/netfilter/nf_conntrack_acct
        target: /host-proc/sys/net/netfilter/nf_conntrack_acct
        bind: {create_host_path: true}
      - type: bind
        source: /etc/timezone
        target: /etc/timezone
        read_only: true
        bind: {create_host_path: true}
      - type: bind
        source: /etc/localtime
        target: /etc/localtime
        read_only: true
        bind: {create_host_path: true}
  isard-webapp:
    container_name: isard-webapp
    depends_on:
      isard-api:
        condition: service_healthy
        required: true
      isard-engine:
        condition: service_healthy
        required: true
    environment:
      API_ISARDVDI_SECRET: tCvVKufwiVyqmSvSHCkB7x/FNCsSxthuVKmBxZy5ElI=
      DOMAIN: solaris.isardvdi.cat
      GRAFANA_WEBAPP_URL: null
      LOG_LEVEL: INFO
      OPERATIONS_API_ENABLED: null
      USAGE: null
    image: registry.gitlab.com/isard/isardvdi/webapp:main
    logging:
      driver: json-file
      options:
        max-file: "5"
        max-size: 10m
        tag: '{{.ImageName}}|{{.Name}}|{{.ImageFullID}}|{{.FullID}}'
    networks:
      isard-network:
        ipv4_address: 172.31.255.26
    volumes:
      - type: bind
        source: /etc/timezone
        target: /etc/timezone
        read_only: true
        bind: {create_host_path: true}
      - type: bind
        source: /etc/localtime
        target: /etc/localtime
        read_only: true
        bind: {create_host_path: true}
  isard-websockify:
    container_name: isard-websockify
    environment:
      API_DOMAIN: null
      LOG_LEVEL: INFO
      VIDEO_HYPERVISOR_HOSTNAMES: null
      VIDEO_HYPERVISOR_PORTS: null
    image: registry.gitlab.com/isard/isardvdi/websockify:main
    logging:
      driver: json-file
      options:
        max-file: "5"
        max-size: 10m
        tag: '{{.ImageName}}|{{.Name}}|{{.ImageFullID}}|{{.FullID}}'
    networks:
      isard-network:
        ipv4_address: 172.31.255.27
    volumes:
      - type: bind
        source: /etc/timezone
        target: /etc/timezone
        read_only: true
        bind: {create_host_path: true}
      - type: bind
        source: /etc/localtime
        target: /etc/localtime
        read_only: true
        bind: {create_host_path: true}
networks:
  isard-network:
    name: isard-network
    driver: bridge
    driver_opts:
      com.docker.network.driver.mtu: "9000"
    ipam:
      config:
        - subnet: 172.31.255.0/24
