  isard-redis:
    command:
      - /bin/sh
      - -c
      - redis-server --port "$$REDIS_PORT" --requirepass "$$REDIS_PASSWORD"
    container_name: isard-redis
    environment:
      REDIS_ARGS: --port 6379
      REDIS_PASSWORD: null
      REDIS_PORT: "6379"
    healthcheck:
      test:
        - CMD-SHELL
        - redis-cli -p $$REDIS_PORT ping | grep PONG
      interval: 5s
      start_period: 5m0s
    image: redis:alpine3.20
    logging:
      driver: json-file
      options:
        max-file: "5"
        max-size: 10m
        tag: '{{.ImageName}}|{{.Name}}|{{.ImageFullID}}|{{.FullID}}'
    networks:
      isard-network:
        ipv4_address: 172.31.255.12
