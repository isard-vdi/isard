#!/usr/bin/env bash
# Pre-commit hook: runs lint checks relevant to changed files
# Install: git config core.hooksPath .githooks  (or `make setup-hooks`)

set -e

CHANGED=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$CHANGED" ]; then
    exit 0
fi

FAILED=0

# Python files
if echo "$CHANGED" | grep -qE '\.py$'; then
    echo ">> Running lint-python..."
    make lint-python || FAILED=1
fi

# Golang files
if echo "$CHANGED" | grep -qE '\.go$'; then
    echo ">> Running lint-go..."
    make lint-go || FAILED=1
fi

# Vue 3 frontend
if echo "$CHANGED" | grep -q '^component/frontend/'; then
    echo ">> Running lint-frontend..."
    make lint-frontend || FAILED=1
fi

# Old frontend
if echo "$CHANGED" | grep -q '^old-frontend/'; then
    echo ">> Running lint-old-frontend..."
    make lint-old-frontend || FAILED=1
fi

# Protobuf
if echo "$CHANGED" | grep -qE '\.proto$|buf\.yaml'; then
    echo ">> Running lint-protobuf..."
    make lint-protobuf || FAILED=1
fi

# Dockerfiles / system-deps pyproject sections
if echo "$CHANGED" | grep -qE '(^|/)Dockerfile$|pyproject\.toml$'; then
    echo ">> Running lint-system-deps..."
    make lint-system-deps || FAILED=1
fi

# Grafana Alloy config
if echo "$CHANGED" | grep -qE '\.alloy$'; then
    echo ">> Running lint-alloy..."
    make lint-alloy || FAILED=1
fi

if [ $FAILED -ne 0 ]; then
    echo ""
    echo "Pre-commit checks failed. Fix the issues and try again."
    exit 1
fi
